---
import { getCollection } from 'astro:content';
const allArticles = await getCollection('articles');
const sorted = [...allArticles].sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0));
const popularArticles = sorted.slice(0, 10);
const rankingMarkets = sorted.filter(a => a.data.category_slug === 'markets').slice(0, 5);
const rankingModel = sorted.filter(a => a.data.category_slug === 'model').slice(0, 5);

const getArticleUrl = (article) => {
  const cat = article.data.category_slug || 'business';
  const slug = article.data.article_slug || article.id;
  return `/article/${cat}/${slug}`;
};
---

<style>
  .also-read { max-width: 1200px; margin: 0 auto; padding: 0 24px 40px; }
  .also-read h2 { font-size: 16px; font-weight: 900; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid #003f88; color: #1a1a1a; }
  .also-read-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .also-block { background: #fff; border-radius: 10px; overflow: hidden; }
  .also-title { background: #003f88; color: #fff; font-size: 12px; font-weight: 900; padding: 8px 12px; }
  .also-card { display: flex; gap: 8px; padding: 8px 10px; border-bottom: 1px solid #f0f0f0; text-decoration: none; color: inherit; align-items: flex-start; }
  .also-card:last-child { border-bottom: none; }
  .also-card:hover { background: #f9f9f9; }
  .also-card img { width: 60px; height: 46px; object-fit: cover; border-radius: 4px; flex-shrink: 0; }
  .also-card-title { font-size: 12px; font-weight: 700; line-height: 1.4; color: #1a1a1a; }
  .also-card-lead { font-size: 11px; color: #888; margin-top: 2px; line-height: 1.3; }
  .also-empty { padding: 12px; font-size: 12px; color: #999; text-align: center; }
  @media (max-width: 768px) { .also-read-grid { grid-template-columns: 1fr; } }
</style>

<section class="also-read">
  <h2>この記事も読まれています</h2>
  <div class="also-read-grid">
    <div class="also-block">
      <div class="also-title">🔥 人気記事</div>
      {popularArticles.map((a) => (
        <a class="also-card" href={getArticleUrl(a)}>
          <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" />
          <div>
            <div class="also-card-title">{a.data.title.slice(0, 36)}{a.data.title.length > 36 ? '...' : ''}</div>
            <div class="also-card-lead">{(a.body || '').replace(/[#\n]/g, ' ').slice(0, 50)}...</div>
          </div>
        </a>
      ))}
    </div>
    <div class="also-block">
      <div class="also-title">📈 マーケット</div>
      {rankingMarkets.length === 0 ? (
        <div class="also-empty">現在記事がありません</div>
      ) : rankingMarkets.map((a) => (
        <a class="also-card" href={getArticleUrl(a)}>
          <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" />
          <div>
            <div class="also-card-title">{a.data.title.slice(0, 36)}{a.data.title.length > 36 ? '...' : ''}</div>
            <div class="also-card-lead">{(a.body || '').replace(/[#\n]/g, ' ').slice(0, 50)}...</div>
          </div>
        </a>
      ))}
    </div>
    <div class="also-block">
      <div class="also-title">🤖 モデル</div>
      {rankingModel.length === 0 ? (
        <div class="also-empty">現在記事がありません</div>
      ) : rankingModel.map((a) => (
        <a class="also-card" href={getArticleUrl(a)}>
          <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" />
          <div>
            <div class="also-card-title">{a.data.title.slice(0, 36)}{a.data.title.length > 36 ? '...' : ''}</div>
            <div class="also-card-lead">{(a.body || '').replace(/[#\n]/g, ' ').slice(0, 50)}...</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>