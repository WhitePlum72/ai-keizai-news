---
const { currentCategory = '' } = Astro.props;

const navItems = [
  { slug: '', href: '/', label: 'トップ' },
  { slug: 'markets', href: '/markets/', label: '市場・株価' },
  { slug: 'infrastructure', href: '/infrastructure/', label: 'AIインフラ' },
  { slug: 'model', href: '/model/', label: '基盤モデル' },
  { slug: 'agents', href: '/agents/', label: 'AIエージェント' },
  { slug: 'products', href: '/products/', label: 'プロダクト' },
  { slug: 'research', href: '/research/', label: '研究' },
  { slug: 'policy', href: '/policy/', label: '政策' },
  { slug: 'company', href: '/company/', label: '企業DB' },
  { slug: 'storygraph', href: '/storygraph/', label: 'StoryGraph' },
  { slug: 'radar', href: '/radar/', label: 'Radar' },
  { slug: 'search', href: '/search/', label: 'Search' },
  { slug: 'editorial-policy', href: '/editorial-policy/', label: '編集方針' },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    color-scheme: dark;
    --site-bg: #07090d;
    --site-panel: #0d1118;
    --site-line: rgba(255,255,255,.10);
    --site-line-strong: rgba(255,255,255,.16);
    --site-ink: #f0f4f8;
    --site-muted: #8a9ab8;
    --site-blue: #5a9eff;
    --site-cyan: #5cd8ce;
    --site-max: 1440px;
    --site-sans: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --site-mono: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--site-line);
    background: rgba(7,9,13,.88);
    backdrop-filter: blur(18px);
  }

  .site-header-inner {
    width: min(100% - 32px, var(--site-max));
    min-height: 62px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--site-ink);
    text-decoration: none;
    font-weight: 900;
    letter-spacing: -.02em;
  }

  .site-brand-mark {
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border: 1px solid var(--site-line-strong);
    border-radius: 7px;
    background: linear-gradient(145deg,#e2e8f0,#94a3b8);
    color: #080b10;
    font-family: var(--site-mono);
    font-size: 11px;
    font-weight: 900;
  }

  .site-nav {
    display: flex;
    justify-content: center;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .site-nav::-webkit-scrollbar { display: none; }

  .site-nav a {
    flex: 0 0 auto;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 7px 11px;
    color: var(--site-muted);
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    transition: color .16s ease, border-color .16s ease, background .16s ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    border-color: rgba(92,216,206,.34);
    background: rgba(92,216,206,.08);
    color: #fff;
  }

  .site-date {
    color: #71809a;
    font-family: var(--site-mono);
    font-size: 10px;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .site-header-inner {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 10px 0;
    }
    .site-nav { justify-content: flex-start; }
    .site-date { display: none; }
  }
</style>

<header class="site-header">
  <div class="site-header-inner">
    <a class="site-brand" href="/">
      <span class="site-brand-mark">AI</span>
      <span>AI経済新聞</span>
    </a>
    <nav class="site-nav" aria-label="メインナビ">
      {navItems.map(item => (
        <a class={currentCategory === item.slug ? 'active' : ''} href={item.href}>{item.label}</a>
      ))}
      <a href="https://umebase.com" target="_blank" rel="noopener noreferrer">UMEBASE</a>
    </nav>
    <div class="site-date">
      {new Date().toLocaleDateString('ja-JP', { year: 'numeric', month: 'numeric', day: 'numeric' })}
    </div>
  </div>
</header>
