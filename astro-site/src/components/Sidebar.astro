---
import { getCollection } from 'astro:content';
import companiesData from '../data/ecosystem/companies.json';

const allArticles = await getCollection('articles');
const sorted = [...allArticles].sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0));
const popularArticles = sorted.slice(0, 5);
const latestArticles = [...allArticles]
  .sort((a, b) => (b.data.published_at || '').localeCompare(a.data.published_at || ''))
  .slice(0, 5);

const featuredCompanies = ['openai', 'nvidia', 'anthropic', 'google', 'microsoft', 'meta', 'amazon', 'xai']
  .map((id) => companiesData.find((c) => c.id === id))
  .filter(Boolean);

const getArticleUrl = (article) => {
  const cat = article.data.category_slug || 'business';
  const slug = article.data.article_slug || article.id;
  return `/article/${cat}/${slug}/`;
};
---

<aside class="sidebar">
  <section class="side-block">
    <div class="side-title">注目記事</div>
    {popularArticles.map((a) => (
      <a class="side-card" href={getArticleUrl(a)}>
        <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" decoding="async" />
        <div>
          <div class="side-card-title">{a.data.title}</div>
          <div class="side-card-meta">{a.data.source || 'AI経済新聞'}</div>
        </div>
      </a>
    ))}
  </section>

  <section class="side-block">
    <div class="side-title">企業で見る</div>
    <div class="company-chip-grid">
      {featuredCompanies.map((company) => (
        <a class="company-chip" href={`/company/${company.id}/`}>
          <span class="logo-frame">
            {company.logo ? (
              <img src={company.logo} alt={company.name} loading="lazy" decoding="async" />
            ) : (
              company.logoText || company.name.slice(0, 2)
            )}
          </span>
          <span>{company.name}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="side-block">
    <div class="side-title">最新記事</div>
    {latestArticles.map((a) => (
      <a class="side-card" href={getArticleUrl(a)}>
        <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" decoding="async" />
        <div>
          <div class="side-card-title">{a.data.title}</div>
          <div class="side-card-meta">{a.data.published_at || ''}</div>
        </div>
      </a>
    ))}
  </section>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 84px;
    height: fit-content;
    display: grid;
    gap: 14px;
  }
  .side-block {
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 14px;
    background: rgba(255,255,255,.035);
    backdrop-filter: blur(14px);
  }
  .side-title {
    border-bottom: 1px solid rgba(255,255,255,.09);
    padding: 11px 13px;
    color: #5cd8ce;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .side-card {
    display: flex;
    gap: 10px;
    padding: 11px 12px;
    border-bottom: 1px solid rgba(255,255,255,.075);
    color: inherit;
    text-decoration: none;
    transition: background .16s ease, transform .16s ease;
  }
  .side-card:last-child { border-bottom: 0; }
  .side-card:hover { background: rgba(92,216,206,.065); }
  .side-card img {
    width: 72px;
    height: 52px;
    object-fit: cover;
    border-radius: 8px;
    flex: 0 0 auto;
    background: rgba(255,255,255,.04);
  }
  .side-card-title {
    color: #eef5ff;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 12px;
    font-weight: 800;
    line-height: 1.55;
  }
  .side-card-meta {
    margin-top: 4px;
    color: #7f8da3;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
  }
  .company-chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 12px;
  }
  .company-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 999px;
    background: rgba(0,0,0,.22);
    padding: 6px 9px 6px 6px;
    color: #dbe7f5;
    text-decoration: none;
    font-size: 11px;
    font-weight: 800;
    transition: border-color .16s ease, background .16s ease, transform .16s ease;
  }
  .company-chip:hover {
    border-color: rgba(92,216,206,.48);
    background: rgba(92,216,206,.08);
    transform: translateY(-1px);
  }
  .logo-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 999px;
    background: rgba(255,255,255,.055);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 9px;
    font-weight: 900;
  }
  .logo-frame img {
    display: block;
    max-width: 72%;
    max-height: 72%;
    object-fit: contain;
  }
  @media (max-width: 980px) {
    .sidebar { position: static; }
  }
</style>
