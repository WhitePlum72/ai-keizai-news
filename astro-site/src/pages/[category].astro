---
import { getCollection } from "astro:content";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Sidebar from "../components/Sidebar.astro";
import companiesData from "../data/ecosystem/companies.json";

const CATEGORIES = [
  {
    slug: "markets",
    label: "市場・株価",
    eyebrow: "Market Intelligence",
    description: "AI関連株、半導体サイクル、データセンター投資、資本市場の動きを構造で読む。",
    topics: ["AI関連株", "半導体市況", "データセンター投資", "資金調達"],
    sectors: ["infrastructure", "enterprise"],
  },
  {
    slug: "infrastructure",
    label: "AIインフラ",
    eyebrow: "AI Infrastructure",
    description: "GPU、半導体、クラウド、電力、データセンターまで、AI産業を支える土台を追う。",
    topics: ["GPU供給網", "HBM / CoWoS", "クラウド基盤", "電力制約"],
    sectors: ["infrastructure"],
  },
  {
    slug: "model",
    label: "基盤モデル",
    eyebrow: "Foundation Models",
    description: "OpenAI、Anthropic、Google、Meta、xAIなどのモデル競争と技術潮流を整理する。",
    topics: ["推論モデル", "マルチモーダル", "オープンモデル", "モデル価格"],
    sectors: ["foundation", "opensource", "china-ai"],
  },
  {
    slug: "business",
    label: "ビジネス",
    eyebrow: "Business Strategy",
    description: "AI企業の事業戦略、提携、買収、導入事例、収益化の動きを追う。",
    topics: ["提携", "収益化", "導入事例", "企業戦略"],
    sectors: ["enterprise", "foundation"],
  },
  {
    slug: "research",
    label: "研究",
    eyebrow: "Research Desk",
    description: "論文、評価手法、モデル安全性、エージェント研究など、AIの最前線を読む。",
    topics: ["AI安全性", "評価", "ロボティクス研究", "学習手法"],
    sectors: ["research", "foundation"],
  },
  {
    slug: "policy",
    label: "政策",
    eyebrow: "Policy Watch",
    description: "AI規制、輸出規制、安全保障、各国政策が企業競争へ与える影響を整理する。",
    topics: ["AI規制", "輸出規制", "安全保障", "著作権"],
    sectors: ["china-ai", "japan"],
  },
  {
    slug: "products",
    label: "プロダクト",
    eyebrow: "Product Intelligence",
    description: "ChatGPT、Claude、Gemini、生成AIアプリ、開発者向けAIツールの進化を追う。",
    topics: ["生成AI", "開発者ツール", "AIアプリ", "エージェント"],
    sectors: ["generative-ai", "agents", "enterprise"],
  },
  {
    slug: "agents",
    label: "AIエージェント",
    eyebrow: "Agent Economy",
    description: "検索、開発、業務自動化を担うAIエージェントのプレイヤーと基盤を整理する。",
    topics: ["コーディングAI", "業務自動化", "Agent Framework", "検索エージェント"],
    sectors: ["agents"],
  },
  {
    slug: "robotics",
    label: "ロボティクス",
    eyebrow: "Robotics",
    description: "ヒューマノイド、産業ロボット、ロボット基盤モデルとAI計算資源の関係を見る。",
    topics: ["ヒューマノイド", "Robot AI", "NVIDIA Isaac", "産業ロボット"],
    sectors: ["robotics"],
  },
  {
    slug: "generative-ai",
    label: "生成AI",
    eyebrow: "Creative AI",
    description: "画像生成、動画生成、音声生成、クリエイティブツールの市場構造を整理する。",
    topics: ["画像生成", "動画生成", "音声生成", "Creative Tools"],
    sectors: ["generative-ai"],
  },
];

export async function getStaticPaths() {
  return CATEGORIES.map(cat => ({ params: { category: cat.slug }, props: { cat } }));
}

const { cat } = Astro.props;
const allArticles = await getCollection("articles");
const articles = allArticles
  .filter(a => a.data.category_slug === cat.slug || a.id.startsWith(cat.slug + "/"))
  .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0));

const relatedCompanies = companiesData
  .filter(company => cat.sectors.includes(company.sector))
  .sort((a, b) => (b.score || 0) - (a.score || 0))
  .slice(0, 10);

const getArticleUrl = (article) => {
  const category = article.data.category_slug || "business";
  const slug = article.data.article_slug || article.id;
  return `/article/${category}/${slug}/`;
};

const formatDate = (str) => {
  if (!str) return "";
  const d = new Date(str);
  return Number.isNaN(d.getTime()) ? str : d.toLocaleDateString("ja-JP", { month: "numeric", day: "numeric" });
};

const canonicalUrl = `https://aikeizai.jp/${cat.slug}/`;
const pageTitle = `${cat.label} | AI経済新聞`;
const pageDesc = cat.description;
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:image" content="https://aikeizai.jp/ogp.png" />
</head>
<body>
  <Header currentCategory={cat.slug} />
  <div class="page-shell">
    <div class="category-hero">
      <div>
        <p class="eyebrow">{cat.eyebrow}</p>
        <h1>{cat.label}</h1>
        <p class="lead">{cat.description}</p>
      </div>
      <div class="hero-logos" aria-label="関連企業">
        {relatedCompanies.slice(0, 6).map(company => (
          <a class="logo-frame" href={`/company/${company.id}/`} title={company.name}>
            {company.logo ? <img src={company.logo} alt={company.name} loading="lazy" decoding="async" /> : company.logoText}
          </a>
        ))}
      </div>
    </div>

    <div class="topic-grid">
      {cat.topics.map(topic => (
        <div class="topic-card">
          <span class="topic-dot"></span>
          <h2>{topic}</h2>
          <p>{cat.label}を理解するための重要テーマ。</p>
        </div>
      ))}
    </div>

    <div class="content-grid">
      <main>
        <div class="section-head">
          <p class="eyebrow">Latest Articles</p>
          <h2>最新記事</h2>
        </div>
        {articles.length === 0 ? (
          <div class="empty">このカテゴリの記事は準備中です。</div>
        ) : (
          <div class="article-grid">
            {articles.map(article => (
              <a class="article-card" href={getArticleUrl(article)}>
                <img src={article.data.image_url || "/ogp.png"} alt={article.data.title} loading="lazy" decoding="async" />
                <div class="article-body">
                  <div class="article-meta">
                    <span>{cat.label}</span>
                    <span>{formatDate(article.data.published_at)}</span>
                    {article.data.source_label && <strong>{article.data.source_label}</strong>}
                  </div>
                  <h3>{article.data.title}</h3>
                  <p>{(article.body || "").replace(/[#*`\[\]\n]/g, " ").replace(/\s+/g, " ").trim().slice(0, 96)}</p>
                  <span class="read-link">読む →</span>
                </div>
              </a>
            ))}
          </div>
        )}

        {relatedCompanies.length > 0 && (
          <section class="related-company-section">
            <div class="section-head">
              <p class="eyebrow">Company Map</p>
              <h2>関連企業</h2>
            </div>
            <div class="company-grid">
              {relatedCompanies.map(company => (
                <a class="company-card" href={`/company/${company.id}/`}>
                  <span class="logo-frame">
                    {company.logo ? <img src={company.logo} alt={company.name} loading="lazy" decoding="async" /> : company.logoText}
                  </span>
                  <div>
                    <h3>{company.name}</h3>
                    <p>{company.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </main>
      <Sidebar />
    </div>
  </div>
  <Footer />
</body>
</html>

<style>
  :global(body) { margin: 0; background: #07090d; color: #f0f4f8; font-family: 'Noto Sans JP', -apple-system, sans-serif; }
  :global(a) { color: inherit; text-decoration: none; }
  .page-shell { width: min(100% - 32px, 1440px); margin: 0 auto; padding: 34px 0 56px; }
  .category-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 18px;
    background:
      radial-gradient(circle at 15% 20%, rgba(90,158,255,.16), transparent 28rem),
      rgba(255,255,255,.035);
    padding: clamp(22px, 4vw, 38px);
    backdrop-filter: blur(14px);
  }
  .eyebrow { margin: 0 0 8px; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  h1 { margin: 0; font-size: clamp(30px, 5vw, 54px); font-weight: 950; letter-spacing: -.05em; }
  .lead { max-width: 760px; margin: 14px 0 0; color: #9fb0c8; font-size: 14px; line-height: 1.9; }
  .hero-logos { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 10px; max-width: 360px; }
  .logo-frame { display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; overflow: hidden; border: 1px solid rgba(255,255,255,.12); border-radius: 14px; background: rgba(255,255,255,.055); color: #fff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 900; }
  .logo-frame img { display: block; max-width: 72%; max-height: 72%; object-fit: contain; }
  .topic-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin: 18px 0; }
  .topic-card, .empty, .article-card, .company-card {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 14px;
    background: rgba(255,255,255,.035);
    backdrop-filter: blur(14px);
  }
  .topic-card { padding: 16px; }
  .topic-dot { display: block; width: 8px; height: 8px; border-radius: 999px; background: #5cd8ce; box-shadow: 0 0 18px rgba(92,216,206,.7); margin-bottom: 12px; }
  .topic-card h2 { margin: 0; font-size: 14px; font-weight: 900; }
  .topic-card p { margin: 6px 0 0; color: #8a9ab8; font-size: 12px; line-height: 1.7; }
  .content-grid { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 22px; align-items: start; }
  .section-head { display: flex; align-items: end; justify-content: space-between; gap: 12px; margin: 24px 0 14px; }
  .section-head h2 { margin: 0; font-size: 22px; font-weight: 950; letter-spacing: -.03em; }
  .article-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  .article-card { overflow: hidden; transition: transform .18s ease, border-color .18s ease, background .18s ease; }
  .article-card:hover, .company-card:hover { transform: translateY(-3px); border-color: rgba(92,216,206,.36); background: rgba(92,216,206,.055); }
  .article-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; background: #111827; }
  .article-body { padding: 14px 15px 16px; }
  .article-meta { display: flex; flex-wrap: wrap; gap: 7px; color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; }
  .article-meta strong { color: #e6b84a; }
  .article-card h3 { margin: 9px 0 0; color: #f7fbff; font-size: 15px; line-height: 1.6; font-weight: 850; }
  .article-card p { margin: 8px 0 0; color: #8a9ab8; font-size: 12px; line-height: 1.75; }
  .read-link { display: inline-flex; margin-top: 12px; color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 900; }
  .empty { padding: 36px; text-align: center; color: #8a9ab8; }
  .company-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .company-card { display: flex; gap: 12px; padding: 14px; transition: transform .18s ease, border-color .18s ease, background .18s ease; }
  .company-card h3 { margin: 0; font-size: 14px; font-weight: 900; }
  .company-card p { margin: 4px 0 0; color: #8a9ab8; font-size: 12px; line-height: 1.65; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  @media (max-width: 1100px) { .content-grid { grid-template-columns: 1fr; } .topic-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 720px) { .category-hero { grid-template-columns: 1fr; } .hero-logos { justify-content: flex-start; } .article-grid, .company-grid, .topic-grid { grid-template-columns: 1fr; } }
</style>
