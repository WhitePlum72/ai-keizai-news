---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const canonicalUrl = "https://aikeizai.jp/about/";
const description = "AI経済新聞は、UMEBASEが運営するAI業界の日本語リファレンス / 構造分析メディアです。一次情報、企業DB、StoryGraph、業界マップを通じてAI産業の変化を整理します。";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "AI経済新聞について",
  description,
  url: canonicalUrl,
  inLanguage: "ja",
  publisher: {
    "@type": "Organization",
    name: "UMEBASE",
    url: "https://umebase.com/",
  },
};
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI経済新聞について | AI経済新聞</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content="AI経済新聞について" />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://aikeizai.jp/og/default.svg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://aikeizai.jp/og/default.svg" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <Header />
  <main>
    <section class="page-hero">
      <div class="w">
        <p class="eyebrow">About AI Keizai</p>
        <h1>AI業界を、ニュースではなく構造として読む。</h1>
        <p class="lead">{description}</p>
        <div class="hero-links">
          <a href="/editorial-policy/">編集方針</a>
          <a href="/methodology/">分析手法</a>
          <a href="https://umebase.com" target="_blank" rel="noopener noreferrer">運営会社 UMEBASE</a>
        </div>
      </div>
    </section>

    <section class="w grid">
      {[
        ["役割", "AI経済新聞は、生成AI、半導体、クラウド、AIエージェント、政策、資本市場を横断し、個別ニュースを産業構造の中で理解するための日本語リファレンスを目指します。"],
        ["一次情報", "企業公式発表、IR資料、GitHub、arXiv、政府・規制当局資料、技術文書を起点に、読者が原典へ戻れる形で情報を整理します。"],
        ["構造分析", "企業DB、StoryGraph、業界マップを用い、供給網、技術依存、競合、投資、顧客関係を静的HTMLとしても読める形にします。"],
        ["運営責任", "AI経済新聞はUMEBASE編集部の責任で運営されます。広告・スポンサーの有無にかかわらず、編集判断の独立性を保ちます。"],
      ].map(([title, text]) => (
        <article class="card">
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </section>

    <section class="w panel">
      <p class="eyebrow">Operating Company</p>
      <h2>運営：UMEBASE</h2>
      <p>UMEBASEは、AI・テクノロジー・産業構造を分析・可視化するメディア事業会社です。AI経済新聞を通じて、一次情報に基づく構造化報道、企業データベース、StoryGraph型の業界可視化を提供します。</p>
      <dl>
        <div><dt>運営会社</dt><dd><a href="https://umebase.com" target="_blank" rel="noopener noreferrer">UMEBASE</a></dd></div>
        <div><dt>編集方針</dt><dd><a href="/editorial-policy/">編集方針・一次情報ポリシー</a></dd></div>
        <div><dt>訂正依頼</dt><dd><a href="mailto:info@umebase.com">info@umebase.com</a></dd></div>
      </dl>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  :global(body) { margin: 0; background: radial-gradient(circle at 18% 0%, rgba(90,158,255,.14), transparent 34rem), #07090d; color: #f0f4f8; font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif; }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1120px); margin-inline: auto; }
  .page-hero { border-bottom: 1px solid rgba(255,255,255,.09); padding: 58px 0 34px; }
  .eyebrow { margin: 0; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  h1 { max-width: 820px; margin: 8px 0 0; font-size: clamp(34px, 5vw, 62px); line-height: 1.12; letter-spacing: -.04em; }
  .lead { max-width: 780px; color: #b7c4d8; line-height: 1.9; }
  .hero-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
  .hero-links a, .panel a { color: #5cd8ce; font-weight: 900; }
  .hero-links a { border: 1px solid rgba(92,216,206,.24); border-radius: 999px; background: rgba(92,216,206,.07); padding: 9px 13px; font-size: 12px; }
  .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; padding: 26px 0 0; }
  .card, .panel { border: 1px solid rgba(255,255,255,.10); border-radius: 16px; background: rgba(255,255,255,.035); padding: 22px; }
  .card h2, .panel h2 { margin: 4px 0 10px; font-size: 22px; }
  .card p, .panel p, dd { color: #b7c4d8; line-height: 1.9; }
  .panel { margin-top: 16px; margin-bottom: 54px; }
  dl { display: grid; gap: 8px; margin: 18px 0 0; }
  dl div { display: grid; grid-template-columns: 130px 1fr; border-top: 1px solid rgba(255,255,255,.08); padding-top: 10px; }
  dt { color: #7f8da3; font-size: 12px; }
  dd { margin: 0; }
  @media (max-width: 760px) { .grid, dl div { grid-template-columns: 1fr; } }
</style>
