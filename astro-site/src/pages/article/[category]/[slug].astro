---
import { getCollection, render } from 'astro:content';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Sidebar from '../../../components/Sidebar.astro';
import AlsoRead from '../../../components/AlsoRead.astro';
import JsonLd from '../../../components/JsonLd.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => {
    const catSlug = article.data.category_slug || 'business';
    const idSlug = article.id.includes('/')
      ? article.id.split('/').pop()
      : article.id;
    const artSlug = article.data.article_slug || idSlug;
    return {
      params: { category: catSlug, slug: artSlug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const allArticles = await getCollection('articles');

const currentTopics = new Set(article.data.topics_json ?? []);
const currentCompanies = new Set(article.data.companies_json ?? []);

const relatedArticles = allArticles
  .filter(a => a.id !== article.id)
  .map(a => {
    const aTopics = a.data.topics_json ?? [];
    const aCompanies = a.data.companies_json ?? [];

    // トピック一致数（重み2）+ 企業一致数（重み3）+ 同カテゴリボーナス（重み1）
    const topicScore = aTopics.filter(t => currentTopics.has(t)).length * 2;
    const companyScore = aCompanies.filter(c => currentCompanies.has(c)).length * 3;
    const categoryBonus = a.data.category_slug === article.data.category_slug ? 1 : 0;
    const relevance = topicScore + companyScore + categoryBonus;

    return { article: a, relevance };
  })
  .filter(({ relevance }) => relevance > 0)  // 関連性ゼロは除外
  .sort((a, b) =>
    b.relevance - a.relevance ||
    (b.article.data.buzz_score || 0) - (a.article.data.buzz_score || 0)
  )
  .slice(0, 3)
  .map(({ article }) => article);
const { Content } = await render(article);

const description = article.body.slice(0, 120).replace(/[#\n]/g, '');
const canonicalUrl = `https://aikeizai.jp/article/${article.data.category_slug || 'business'}/${article.data.article_slug || article.id}/`;
const ogImage = article.data.image_url ? (article.data.image_url.startsWith('http') ? article.data.image_url : 'https://aikeizai.jp' + article.data.image_url) : 'https://aikeizai.jp/ogp.png';

const getArticleUrl = (a) => {
  const cat = a.data.category_slug || 'business';
  const slug = a.data.article_slug || a.id;
  return `/article/${cat}/${slug}/`;
};

const getCatLabel = (slug) => ({
  model: 'モデル',
  business: 'ビジネス',
  markets: 'AI関連株',
  infrastructure: 'インフラ',
  research: '研究',
  policy: '政策',
  products: 'プロダクト',
}[slug] || slug);

// JsonLd コンポーネントで使用
const categoryLabel = getCatLabel(article.data.category_slug);
---

<html lang="ja">
<head>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-R8C9ET314H"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-R8C9ET314H');
  </script>
  
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{article.data.title} | AI経済新聞</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
<meta property="og:title" content={article.data.title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1280" />
<meta property="og:image:height" content="720" />
<meta property="og:image:alt" content={article.data.title} />
<meta property="og:type" content="article" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content="AI経済新聞" />
<meta property="og:locale" content="ja_JP" />
<meta property="article:published_time" content={article.data.published_at} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={article.data.title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<JsonLd
  type="article"
  headline={article.data.title}
  description={article.data.summary ?? description}
  url={canonicalUrl}
  imageUrl={article.data.image_url}
  datePublished={article.data.published_at}
  dateModified={article.data.published_at}
  categoryName={categoryLabel}
  categorySlug={article.data.category_slug}
  articleSlug={article.data.article_slug}
/>

  <style>
    body { margin: 0; font-family: 'Noto Sans JP', -apple-system, sans-serif; background: #f4f6f8; color: #17202a; }
    a { color: inherit; text-decoration: none; }

    .layout { display: grid; grid-template-columns: 1fr 340px; gap: 24px; max-width: 1200px; margin: 0 auto; padding: 24px; }

    .article { background: #fff; border-radius: 3px; overflow: hidden; }
    .article > img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }

    .article-body { padding: 28px 32px 24px; font-size: 16px; color: #1a1a2e; line-height: 2.0; }
    .article-body h1 { font-size: 22px; font-weight: 900; line-height: 1.5; margin: 0 0 16px; color: #1a1a2e; }
    .article-body h2 { font-size: 17px; font-weight: 900; color: #003f88; margin: 40px 0 14px; padding: 10px 14px; background: #f0f4fa; border-left: 4px solid #003f88; border-radius: 0 6px 6px 0; line-height: 1.5; }
    .article-body p { margin-bottom: 20px; line-height: 2.0; }
    .article-body hr { border: none; border-top: 1px solid #eee; margin: 32px 0; }

    .article-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #eee; font-size: 12px; color: #888; }
    .category-badge { background: #003f88; color: #fff; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; }
    .source-badge { background: #e8f0fe; color: #003f88; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; }

    .source-link { margin-top: 32px; padding-top: 20px; border-top: 1px solid #eee; text-align: center; }
    .source-link a { display: inline-block; padding: 10px 20px; background: #003f88; color: #fff; border-radius: 6px; font-size: 13px; font-weight: 700; transition: background 0.2s; }
    .source-link a:hover { background: #002a5c; }

    .related { max-width: 1200px; margin: 0 auto; padding: 0 24px 24px; }
    .related h2 { font-size: 16px; font-weight: 900; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid #003f88; color: #1a1a1a; }
    .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .related-card { background: #fff; border-radius: 3px; overflow: hidden; display: block; transition: transform 0.15s; }
    .related-card:hover { transform: translateY(-2px); }
    .related-card img { width: 100%; height: 120px; object-fit: cover; }
    .related-card-body { padding: 10px; }
    .related-card-title { font-size: 13px; font-weight: 700; margin-bottom: 4px; line-height: 1.4; }
    .related-card-cat { font-size: 10px; color: #003f88; font-weight: 700; margin-bottom: 4px; }
    .article-image-wrap { position: relative; }
    .article-image-wrap img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
    .image-credit { font-size: 10px; color: #999; text-align: right; padding: 4px 12px 0; }
    .image-credit a { color: #999; text-decoration: underline; }
    .topic-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
    .topic-chip { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; background: #f0f4fa; color: #003f88; border: 1px solid #d0ddf5; transition: all 0.15s; text-decoration: none; }
    .topic-chip:hover { background: #003f88; color: #fff; }
    .breadcrumb {
  font-size: 0.8rem;
  color: #888;
  padding: 12px 32px 0;
}
.breadcrumb ol {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  padding: 0;
  margin: 0;
}
.breadcrumb li + li::before {
  content: "›";
  margin: 0 0.4rem;
  color: #bbb;
}
.breadcrumb a {
  color: #555;
  text-decoration: none;
}
.breadcrumb a:hover {
  text-decoration: underline;
}
.breadcrumb li[aria-current="page"] {
  color: #333;
  max-width: 320px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; padding: 12px; gap: 16px; }
      .article-body { padding: 16px; font-size: 15px; }
      .article-body h1 { font-size: 19px; }
      .article-body h2 { font-size: 15px; padding: 8px 12px; margin-top: 28px; }
      .related-grid { grid-template-columns: 1fr; }
      .breadcrumb { padding: 8px 16px 0; }
    }
  </style>
</head>

<body>
  <Header currentCategory={article.data.category_slug} />

  <div class="layout">
    <article class="article">
{article.data.image_url && (
  <div class="article-image-wrap">
    {article.data.image_url.startsWith('http') ? (
      <a href={article.data.source_url} target="_blank" rel="noopener noreferrer" title="画像引用元へ">
        <img src={article.data.image_url} alt={article.data.title} />
      </a>
    ) : (
      <img src={article.data.image_url} alt={article.data.title} />
    )}
    {article.data.image_url.startsWith('http') && (
      <div class="image-credit">
        画像引用元：<a href={article.data.source_url} target="_blank" rel="noopener noreferrer">{article.data.source}</a>
      </div>
    )}
  </div>
)}
<nav aria-label="パンくずリスト" class="breadcrumb">
  <ol>
    <li><a href="/">ホーム</a></li>
    <li><a href={`/${article.data.category_slug}/`}>{categoryLabel}</a></li>
    <li aria-current="page">{article.data.title}</li>
  </ol>
</nav>
      <div class="article-body">
        <div class="article-meta">
          <span class="category-badge">{getCatLabel(article.data.category_slug)}</span>
          {article.data.source_label && (
            <span class="source-badge">{article.data.source_label}</span>
          )}
          <span>{article.data.source || ''}</span>
          <span>{article.data.published_at || ''}</span>
        </div>
        {article.data.topics_json && article.data.topics_json.length > 0 && (
          <div class="topic-chips">
            {article.data.topics_json.map(topic => (
              <a class="topic-chip" href={`/topic/${topic}/`}>#{topic}</a>
            ))}
          </div>
        )}
        <h1>{article.data.title}</h1>
        <Content />
        <div class="source-link">
          <a href={article.data.source_url} target="_blank" rel="noopener noreferrer">
            元記事を読む（{article.data.source}）→
          </a>
        </div>
      </div>
    </article>

    <Sidebar />
  </div>

  {relatedArticles.length > 0 && (
    <section class="related">
      <h2>関連記事</h2>
      <div class="related-grid">
        {relatedArticles.map((a) => (
          <a class="related-card" href={getArticleUrl(a)}>
            <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" />
            <div class="related-card-body">
              <div class="related-card-cat">{getCatLabel(a.data.category_slug)}</div>
              <div class="related-card-title">{a.data.title}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <AlsoRead />
  <Footer />
</body>
</html>