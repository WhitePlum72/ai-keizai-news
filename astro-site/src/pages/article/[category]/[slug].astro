---
import { getCollection, render } from 'astro:content';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Sidebar from '../../../components/Sidebar.astro';
import AlsoRead from '../../../components/AlsoRead.astro';
import JsonLd from '../../../components/JsonLd.astro';
import companiesData from '../../../data/ecosystem/companies.json';
import storygraphsData from '../../../data/ecosystem/storygraphs.json';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => {
    const catSlug = article.data.category_slug || 'business';
    const idSlug = article.id.includes('/') ? article.id.split('/').pop() : article.id;
    const artSlug = article.data.article_slug || idSlug;
    return {
      params: { category: catSlug, slug: artSlug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const allArticles = await getCollection('articles');
const { Content } = await render(article);

const currentTopics = new Set(article.data.topics_json ?? []);
const currentCompanies = new Set(article.data.companies_json ?? []);
const companyMap = new Map(companiesData.map((company) => [company.id, company]));
const relatedCompanies = [...currentCompanies].map((id) => companyMap.get(id)).filter(Boolean).slice(0, 8);

const seoDescription = article.data.description || article.data.meta_description || '';
const plainText = (seoDescription || article.body || '')
  .replace(/[#*`\[\]\n]/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();
const buildDescription = (text) => {
  if (!text) return '';
  if (text.length <= 140) return text;
  const clipped = text.slice(0, 140);
  const sentenceEnd = Math.max(clipped.lastIndexOf('。'), clipped.lastIndexOf('.'));
  return sentenceEnd > 60 ? clipped.slice(0, sentenceEnd + 1) : `${clipped.replace(/[、，\s]+$/g, '')}。`;
};
const description = buildDescription(plainText);
const summaryPoints = Array.isArray(article.data.summaryPoints)
  ? article.data.summaryPoints.map((point) => String(point).trim()).filter(Boolean).slice(0, 3)
  : [];
const keyPoints = summaryPoints.length > 0 ? summaryPoints : (description ? [description] : []);

const relatedArticles = allArticles
  .filter((a) => a.id !== article.id)
  .map((a) => {
    const aTopics = a.data.topics_json ?? [];
    const aCompanies = a.data.companies_json ?? [];
    const topicScore = aTopics.filter((t) => currentTopics.has(t)).length * 2;
    const companyScore = aCompanies.filter((c) => currentCompanies.has(c)).length * 3;
    const categoryBonus = a.data.category_slug === article.data.category_slug ? 1 : 0;
    return { article: a, relevance: topicScore + companyScore + categoryBonus };
  })
  .filter(({ relevance }) => relevance > 0)
  .sort((a, b) => b.relevance - a.relevance || (b.article.data.buzz_score || 0) - (a.article.data.buzz_score || 0))
  .slice(0, 6)
  .map(({ article }) => article);

const getArticleUrl = (a) => {
  const cat = a.data.category_slug || 'business';
  const slug = a.data.article_slug || a.id;
  return `/article/${cat}/${slug}/`;
};

const catLabels = {
  model: '基盤モデル',
  business: 'ビジネス',
  markets: '市場・株価',
  infrastructure: 'AIインフラ',
  research: '研究',
  policy: '政策',
  products: 'プロダクト',
  agents: 'AIエージェント',
  robotics: 'ロボティクス',
  'generative-ai': '生成AI',
};
const categoryLabel = catLabels[article.data.category_slug] || article.data.category_slug || '記事';

const canonicalUrl = `https://aikeizai.jp/article/${article.data.category_slug || 'business'}/${article.data.article_slug || article.id}/`;
const ogImage = article.data.image_url
  ? (article.data.image_url.startsWith('http') ? article.data.image_url : 'https://aikeizai.jp' + article.data.image_url)
  : 'https://aikeizai.jp/ogp.png';
const mapSlugOverrides = {
  nvidia: 'nvidia-empire',
  openai: 'openai-ecosystem',
  huggingface: 'open-source-ai-ecosystem',
  deepseek: 'china-ai-map',
  'sakana-ai': 'japan-ai',
};
const toMapSlug = (companyId) => mapSlugOverrides[companyId] || `${companyId}-ecosystem`;
const relatedGraphCompany = [...currentCompanies].find((id) => storygraphsData.some((graph) => graph.company === id));
const relatedGraphUrl = relatedGraphCompany ? `/map/${toMapSlug(relatedGraphCompany)}/` : '/#ai-ecosystem-map';
const primaryCompany = relatedCompanies[0];
const formatDate = (value) => {
  if (!value) return '';
  const date = new Date(value);
  return Number.isNaN(date.getTime())
    ? value
    : date.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
};
---

<html lang="ja">
<head>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-R8C9ET314H"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-R8C9ET314H');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{article.data.title} | AI経済新聞</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={article.data.title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1280" />
  <meta property="og:image:height" content="720" />
  <meta property="og:image:alt" content={article.data.title} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="AI経済新聞" />
  <meta property="og:locale" content="ja_JP" />
  <meta property="article:published_time" content={article.data.published_at} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={article.data.title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <JsonLd
    type="article"
    headline={article.data.title}
    description={article.data.meta_description ?? description}
    url={canonicalUrl}
    imageUrl={ogImage}
    datePublished={article.data.published_at}
    dateModified={article.data.published_at}
    categoryName={categoryLabel}
    categorySlug={article.data.category_slug}
    articleSlug={article.data.article_slug}
    keywords={article.data.topics_json ?? []}
    sourceUrl={article.data.source_url}
  />
</head>

<body>
  <Header currentCategory={article.data.category_slug} />

  <main>
    <div class="w layout">
      <article class="article-shell">
        <nav class="breadcrumb" aria-label="パンくずリスト">
          <ol>
            <li><a href="/">ホーム</a></li>
            <li><a href={`/${article.data.category_slug}/`}>{categoryLabel}</a></li>
            <li aria-current="page">{article.data.title}</li>
          </ol>
        </nav>

        <header class="article-hero">
          <div class="meta-row">
            <span class="category-badge">{categoryLabel}</span>
            {article.data.source_label && <span class="source-badge">{article.data.source_label}</span>}
            <span>{article.data.source || 'AI経済新聞'}</span>
            <time>掲載: {formatDate(article.data.published_at)}</time>
          </div>
          <h1>{article.data.title}</h1>
          {relatedCompanies.length > 0 && (
            <div class="company-row" aria-label="関連企業">
              {relatedCompanies.map((company) => (
                <a href={`/company/${company.id}/`} title={company.name}>
                  <span class="logo-frame">
                    {company.logo ? (
                      <img src={company.logo} alt={company.name} loading="lazy" decoding="async" />
                    ) : (
                      company.logoText || company.name.slice(0, 2)
                    )}
                  </span>
                  <span>{company.name}</span>
                </a>
              ))}
            </div>
          )}
        </header>

        {article.data.image_url && (
          <figure class="article-image">
            {article.data.image_url.startsWith('http') ? (
              <a href={article.data.source_url} target="_blank" rel="noopener noreferrer">
                <img src={article.data.image_url} alt={article.data.title} loading="eager" fetchpriority="high" decoding="async" />
              </a>
            ) : (
              <img src={article.data.image_url} alt={article.data.title} loading="eager" fetchpriority="high" decoding="async" />
            )}
            {article.data.image_url.startsWith('http') && (
              <figcaption>
                画像出典：<a href={article.data.source_url} target="_blank" rel="noopener noreferrer">{article.data.source}</a>
              </figcaption>
            )}
          </figure>
        )}

        {keyPoints.length > 0 && (
          <section class="key-box">
            <p class="eyebrow">Key Points</p>
            <h2>この記事の要約</h2>
            <div class="key-grid">
              {keyPoints.map((point, index) => (
                <div>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <p>{point}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <div class="topic-chips">
          {(article.data.topics_json ?? []).map((topic) => (
            <a href={`/topic/${topic}/`}>#{topic}</a>
          ))}
        </div>

        <section class="article-body">
          <Content />
        </section>

        {article.data.source_url && (
          <section class="source-panel">
            <div>
              <p class="eyebrow">Primary Source</p>
              <h2>一次情報</h2>
              <p>
                {article.data.source_label || '一次情報'}: {article.data.source || '公式発表'}
                {article.data.source_published_at && <span> / 原文公開: {formatDate(article.data.source_published_at)}</span>}
                {article.data.published_at && <span> / 掲載: {formatDate(article.data.published_at)}</span>}
              </p>
            </div>
            <a href={article.data.source_url} target="_blank" rel="noopener noreferrer">一次情報を確認 →</a>
          </section>
        )}

        <section class="map-cta">
          <div>
            <p class="eyebrow">Industry Map</p>
            <h2>関連する業界構造を見る</h2>
            <p>企業間の供給網、出資、提携、競合関係をStoryGraphと企業データベースで確認できます。</p>
          </div>
          <div class="map-actions">
            {primaryCompany && <a href={`/company/${primaryCompany.id}/`}>{primaryCompany.name}を見る →</a>}
            <a href={relatedGraphUrl}>構造ページへ →</a>
          </div>
        </section>
      </article>

      <Sidebar />
    </div>

    {relatedArticles.length > 0 && (
      <section class="related w">
        <div class="section-head">
          <div>
            <p class="eyebrow">Related</p>
            <h2>関連記事</h2>
          </div>
        </div>
        <div class="related-grid">
          {relatedArticles.map((a) => (
            <a class="related-card" href={getArticleUrl(a)}>
              <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" decoding="async" />
              <div>
                <p>{catLabels[a.data.category_slug] || a.data.category_slug || '記事'}</p>
                <h3>{a.data.title}</h3>
                <span>読む →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <AlsoRead />
  <Footer />
</body>
</html>

<style>
  :global(body) {
    margin: 0;
    background:
      radial-gradient(circle at 20% 0%, rgba(90,158,255,.13), transparent 34rem),
      linear-gradient(180deg, rgba(14,22,40,.88), rgba(7,9,13,0) 520px),
      #07090d;
    color: #f0f4f8;
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1440px); margin-inline: auto; }
  .layout { display: grid; grid-template-columns: minmax(0, 1fr) 340px; gap: 24px; padding: 28px 0; }
  .article-shell {
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 18px;
    background: rgba(255,255,255,.035);
    backdrop-filter: blur(14px);
  }
  .breadcrumb { padding: 16px 22px 0; color: #7f8da3; font-size: 12px; }
  .breadcrumb ol { display: flex; flex-wrap: wrap; gap: 0; list-style: none; padding: 0; margin: 0; }
  .breadcrumb li + li::before { content: "/"; margin: 0 8px; color: #4a5568; }
  .breadcrumb a:hover { color: #5cd8ce; }
  .breadcrumb li[aria-current="page"] { max-width: 520px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .article-hero { padding: 30px 34px 24px; }
  .meta-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; }
  .category-badge, .source-badge { display: inline-flex; align-items: center; border-radius: 999px; padding: 5px 10px; color: #fff; font-size: 10px; font-weight: 900; }
  .category-badge { background: #4d8ef0; }
  .source-badge { border: 1px solid rgba(230,184,74,.3); background: rgba(230,184,74,.12); color: #e6b84a; }
  h1 { margin: 16px 0 0; font-size: clamp(28px, 4vw, 52px); line-height: 1.22; letter-spacing: -.04em; }
  .company-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
  .company-row a { display: inline-flex; align-items: center; gap: 7px; border: 1px solid rgba(255,255,255,.10); border-radius: 999px; background: rgba(0,0,0,.20); padding: 6px 10px 6px 6px; color: #dbe7f5; font-size: 11px; font-weight: 800; }
  .logo-frame { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; overflow: hidden; border: 1px solid rgba(255,255,255,.10); border-radius: 999px; background: rgba(255,255,255,.055); font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; font-weight: 900; }
  .logo-frame img { display: block; max-width: 72%; max-height: 72%; object-fit: contain; }
  .article-image { margin: 0; border-top: 1px solid rgba(255,255,255,.08); border-bottom: 1px solid rgba(255,255,255,.08); background: rgba(0,0,0,.22); }
  .article-image img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
  .article-image figcaption { padding: 7px 14px; color: #7f8da3; text-align: right; font-size: 10px; }
  .article-image figcaption a { text-decoration: underline; }
  .key-box { margin: 24px 34px 0; border: 1px solid rgba(92,216,206,.18); border-radius: 16px; background: rgba(92,216,206,.055); padding: 18px; }
  .eyebrow { margin: 0; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  .key-box h2, .map-cta h2, .section-head h2 { margin: 4px 0 14px; font-size: 22px; letter-spacing: -.03em; }
  .key-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
  .key-grid div { border: 1px solid rgba(255,255,255,.09); border-radius: 12px; background: rgba(0,0,0,.18); padding: 13px; }
  .key-grid span { color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 900; }
  .key-grid p { margin: 7px 0 0; color: #dbe7f5; font-size: 13px; line-height: 1.7; }
  .topic-chips { display: flex; flex-wrap: wrap; gap: 8px; padding: 20px 34px 0; }
  .topic-chips a { border: 1px solid rgba(255,255,255,.10); border-radius: 999px; background: rgba(255,255,255,.035); padding: 6px 10px; color: #dbe7f5; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; }
  .topic-chips a:hover { border-color: rgba(92,216,206,.42); color: #5cd8ce; }
  .article-body { max-width: 820px; margin: 0 auto; padding: 28px 34px 20px; color: #d9e3f1; font-size: 16px; line-height: 2.05; }
  .article-body :global(h2) { margin: 42px 0 14px; border-left: 3px solid #5a9eff; padding-left: 14px; color: #f8fbff; font-size: 22px; line-height: 1.45; }
  .article-body :global(h3) { margin: 30px 0 10px; color: #eef5ff; font-size: 18px; }
  .article-body :global(p) { margin: 0 0 20px; }
  .article-body :global(a) { color: #5cd8ce; text-decoration: underline; text-underline-offset: 3px; }
  .article-body :global(hr) { border: 0; border-top: 1px solid rgba(255,255,255,.10); margin: 32px 0; }
  .source-panel {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: center;
    margin: 0 34px 18px;
    border: 1px solid rgba(230,184,74,.18);
    border-radius: 16px;
    background: rgba(230,184,74,.055);
    padding: 18px;
  }
  .source-panel h2 { margin: 4px 0 6px; font-size: 18px; }
  .source-panel p { margin: 0; color: #b7c4d8; font-size: 13px; line-height: 1.8; }
  .source-panel a, .map-actions a { display: inline-flex; border-radius: 999px; background: #5cd8ce; color: #07111b; padding: 10px 16px; font-size: 12px; font-weight: 900; transition: transform .16s ease; white-space: nowrap; }
  .source-panel a:hover, .map-actions a:hover { transform: translateY(-2px); }
  .map-cta { display: flex; justify-content: space-between; gap: 18px; align-items: center; margin: 0 34px 34px; border: 1px solid rgba(255,255,255,.10); border-radius: 16px; background: rgba(0,0,0,.18); padding: 18px; }
  .map-cta p { margin: 0; color: #aebbd0; line-height: 1.7; }
  .map-actions { display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }
  .related { padding: 4px 0 44px; }
  .section-head { margin-bottom: 14px; }
  .related-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
  .related-card { overflow: hidden; border: 1px solid rgba(255,255,255,.10); border-radius: 16px; background: rgba(255,255,255,.035); transition: transform .16s ease, border-color .16s ease; }
  .related-card:hover { transform: translateY(-3px); border-color: rgba(92,216,206,.42); }
  .related-card img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; background: rgba(255,255,255,.04); }
  .related-card div { padding: 13px; }
  .related-card p { margin: 0; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; font-weight: 900; }
  .related-card h3 { margin: 7px 0 10px; color: #eef5ff; font-size: 14px; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .related-card span { color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 900; }
  @media (max-width: 980px) {
    .layout { grid-template-columns: 1fr; }
    .key-grid, .related-grid { grid-template-columns: 1fr; }
    .map-cta { align-items: flex-start; flex-direction: column; }
  }
  @media (max-width: 560px) {
    .layout { padding: 16px 0; }
    .article-hero, .article-body { padding-left: 18px; padding-right: 18px; }
    .key-box, .map-cta { margin-left: 18px; margin-right: 18px; }
    .topic-chips { padding-left: 18px; padding-right: 18px; }
    .breadcrumb { padding-left: 18px; padding-right: 18px; }
  }
</style>
