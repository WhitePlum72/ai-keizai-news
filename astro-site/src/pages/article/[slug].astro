---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const allArticles = await getCollection('articles');

// 人気記事（buzz_score）
const popularArticles = [...allArticles]
  .sort((a, b) => b.data.buzz_score - a.data.buzz_score)
  .slice(0, 10);

// AI株
const rankingStocks = [...allArticles]
  .filter(a => a.data.category === "AI関連株")
  .sort((a, b) => b.data.buzz_score - a.data.buzz_score)
  .slice(0, 5);

// ビジネス
const rankingBusiness = [...allArticles]
  .filter(a => a.data.category === "ビジネス")
  .sort((a, b) => b.data.buzz_score - a.data.buzz_score)
  .slice(0, 5);

// 関連記事
const relatedArticles = allArticles
  .filter(a => a.data.category === article.data.category && a.id !== article.id)
  .slice(0, 5);

const { Content } = await render(article);

const description = article.body.slice(0, 120).replace(/[#\n]/g, '');
const canonicalUrl = `https://aikeizai.jp/article/${article.id}`;
const ogImage = article.data.image_url || 'https://aikeizai.jp/ogp.png';
---

<html lang="ja">
<head>
<!-- Google Analytics 4 -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-R8C9ET314H"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-R8C9ET314H');
</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{article.data.title} | AI経済新聞</title>
  <meta name="description" content={description} />

  <style>
    body {
      margin: 0;
      font-family: 'Noto Sans JP', -apple-system, sans-serif;
      background: #f4f6f8;
      color: #17202a;
    }

    a { color: inherit; text-decoration: none; }

    .layout {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
    }

    /* ===== 記事 ===== */
    .article {
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
    }

    .article img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      cursor: pointer;
    }

    .article-body {
      padding: 24px 24px 16px 24px;
      line-height: 1.9;
    }

    /* ===== サイドバー ===== */
    .sidebar {
      position: sticky;
      top: 20px;
      height: fit-content;
    }

    .block {
      background: #fff;
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 16px;
    }

    .block h3 {
      font-size: 14px;
      margin-bottom: 10px;
      color: #003f88;
    }

    /* ===== カード ===== */
    .card {
      display: flex;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px solid #eee;
    }

    .card img {
      width: 90px;
      height: 60px;
      object-fit: cover;
      border-radius: 6px;
      flex-shrink: 0;
    }

    .card-title {
      font-size: 13px;
      font-weight: 700;
      line-height: 1.4;
    }

    .card-desc {
      font-size: 11px;
      color: #666;
      margin-top: 3px;
      line-height: 1.3;
    }

    /* ===== 関連記事（下） ===== */
    .related {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px 40px;
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .related-card {
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
    }

    .related-card img {
      width: 100%;
      height: 120px;
      object-fit: cover;
    }
    .source-link {
  margin-top: 32px;
  padding-top: 20px;
    padding-bottom: 8px;
  border-top: 1px solid #eee;
    text-align: center; /* 追加 */
}

.source-link a {
  display: inline-block;
  padding: 10px 20px;
  background: #003f88;
  color: #fff;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  transition: background 0.2s;
}

.source-link a:hover {
  background: #002a5c;
}

.related-card-body {
  padding: 10px;
}

.related-card-title {
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 4px;
  line-height: 1.4;
}

.related-card-lead {
  font-size: 11px;
  color: #666;
  line-height: 1.5;
}
/* ===== この記事も読まれています ===== */
.also-read {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px 40px;
}

.also-read h2 {
  font-size: 16px;
  font-weight: 900;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 2px solid #003f88;
  color: #1a1a1a;
}

.also-read-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.also-block {
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
}

.also-title {
  background: #003f88;
  color: #fff;
  font-size: 12px;
  font-weight: 900;
  padding: 8px 12px;
}

.also-card {
  display: flex;
  gap: 8px;
  padding: 8px 10px;
  border-bottom: 1px solid #f0f0f0;
  text-decoration: none;
  color: inherit;
  align-items: flex-start;
}

.also-card:last-child {
  border-bottom: none;
}

.also-card:hover {
  background: #f9f9f9;
}

.also-card img {
  width: 60px;
  height: 46px;
  object-fit: cover;
  border-radius: 4px;
  flex-shrink: 0;
}

.also-card-title {
  font-size: 12px;
  font-weight: 700;
  line-height: 1.4;
  color: #1a1a1a;
}

.also-card-lead {
  font-size: 11px;
  color: #888;
  margin-top: 2px;
  line-height: 1.3;
}

.also-empty {
  padding: 12px;
  font-size: 12px;
  color: #999;
  text-align: center;
}
/* ===== まとめ記事の見出し ===== */
.article-body h2 {
  font-size: 17px;
  font-weight: 900;
  color: #003f88;
  margin-top: 40px;
  margin-bottom: 14px;
  padding: 10px 14px;
  background: #f0f4fa;
  border-left: 4px solid #003f88;
  border-radius: 0 6px 6px 0;
  line-height: 1.5;
}

@media (max-width: 768px) {
  .also-read-grid {
    grid-template-columns: 1fr;
  }
  @media (max-width: 768px) {
  .layout {
    grid-template-columns: 1fr;
    padding: 12px;
    gap: 16px;
  }

  .sidebar {
    position: static;
  }

  .article-body {
    padding: 16px;
  }

  .article-body h2 {
    font-size: 15px;
    padding: 8px 12px;
  }

  .related-grid {
    grid-template-columns: 1fr;
  }

  .also-read-grid {
    grid-template-columns: 1fr;
  }

  .header-main {
    padding: 8px 12px;
  }

  .logo {
    font-size: 20px;
  }

  .card img {
    width: 70px;
    height: 50px;
  }
}
}
    /* ===== ヘッダー（index.astroと共通） ===== */
.header-top { background: #003f88; color: white; padding: 4px 0; text-align: center; font-size: 11px; }
.header-main { background: #fff; border-bottom: 3px solid #003f88; padding: 10px 20px; display: flex; align-items: center; justify-content: space-between; }
.logo { font-size: 26px; font-weight: 900; color: #003f88; letter-spacing: -1px; text-decoration: none; }
.header-date { font-size: 12px; color: #666; }
.header-sub { background: #fff; border-bottom: 1px solid #ddd; padding: 0 20px; display: flex; overflow-x: auto; }
.nav-item { padding: 8px 14px; font-size: 13px; font-weight: 500; color: #333; border-bottom: 3px solid transparent; white-space: nowrap; text-decoration: none; display: block; }
.nav-item:hover { color: #003f88; border-bottom-color: #003f88; }
  </style>
</head>

<body>
<div class="header-top">AIと経済の最新ニュースを毎朝配信</div>

<header>
  <div class="header-main">
    <a class="logo" href="/">AI<span>経済</span>新聞</a>
    <div class="header-date">
      {new Date().toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' })}
    </div>
  </div>
<nav class="header-sub">
  <a class="nav-item active" href="/">すべて</a>
  <a class="nav-item" href="/model">モデル</a>
  <a class="nav-item" href="/business">ビジネス</a>
  <a class="nav-item" href="/stock">AI関連株</a>
  <a class="nav-item" href="/research">研究</a>
  <a class="nav-item" href="/digest">まとめ</a>
</nav>
</header>
<div class="layout">

  <!-- ===== 記事 ===== -->
  <article class="article">
    {article.data.image_url && (
  <img src={article.data.image_url} alt={article.data.title} />
)}

    <div class="article-body">
      <h1>{article.data.title}</h1>
      <Content />
      <div class="source-link">
  <a href={article.data.source_url} target="_blank" rel="noopener noreferrer">
    元記事を読む（{article.data.source}）→
  </a>
</div>
    </div>
  </article>

  <!-- ===== サイドバー ===== -->
  <aside class="sidebar">

    <!-- 人気記事 -->
    <div class="block">
      <h3>🔥 人気記事</h3>

      {popularArticles.map((a) => (
        <a class="card" href={`/article/${a.id}`}>
          <img src={a.data.image_url || '/ogp.png'} />
          <div>
            <div class="card-title">{a.data.title}</div>
            <div class="card-desc">
              {(a.body || '').slice(0, 80).replace(/[#\n]/g, '')}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- AI株 -->
    <div class="block">
      <h3>📈 AI関連株</h3>

      {rankingStocks.map((a) => (
        <a class="card" href={`/article/${a.id}`}>
          <img src={a.data.image_url || '/ogp.png'} />
          <div>
            <div class="card-title">{a.data.title}</div>
            <div class="card-desc">
              {(a.body || '').slice(0, 80).replace(/[#\n]/g, '')}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- ビジネス -->
    <div class="block">
      <h3>💼 ビジネス</h3>

      {rankingBusiness.map((a) => (
        <a class="card" href={`/article/${a.id}`}>
          <img src={a.data.image_url || '/ogp.png'} />
          <div>
            <div class="card-title">{a.data.title}</div>
            <div class="card-desc">
              {(a.body || '').slice(0, 80).replace(/[#\n]/g, '')}
            </div>
          </div>
        </a>
      ))}
    </div>

  </aside>

</div>

<!-- ===== 関連記事（下） ===== -->
<section class="related">
  <h2>関連記事</h2>

  <div class="related-grid">
    {relatedArticles.map((a) => (
      <a class="related-card" href={`/article/${a.id}`}>
        <img src={a.data.image_url || '/ogp.png'} />
        <div class="related-card-body">
          <div class="related-card-title">{a.data.title}</div>
          <div class="related-card-lead">
            {(a.body || '').replace(/[#\n]/g, ' ').slice(0, 120)}...
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
<!-- ===== この記事も読まれています ===== -->
<section class="also-read">
  <h2>この記事も読まれています</h2>

  <div class="also-read-grid">

    <div class="also-block">
      <div class="also-title">🔥 人気記事</div>
      {popularArticles.map((a) => (
        <a class="also-card" href={`/article/${a.id}`}>
          <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} />
          <div>
            <div class="also-card-title">{a.data.title.slice(0, 36)}{a.data.title.length > 36 ? '...' : ''}</div>
            <div class="also-card-lead">{(a.body || '').replace(/[#\n]/g, ' ').slice(0, 50)}...</div>
          </div>
        </a>
      ))}
    </div>

    <div class="also-block">
      <div class="also-title">📈 AI関連株</div>
      {rankingStocks.length === 0 ? (
        <div class="also-empty">現在記事がありません</div>
      ) : rankingStocks.map((a) => (
        <a class="also-card" href={`/article/${a.id}`}>
          <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} />
          <div>
            <div class="also-card-title">{a.data.title.slice(0, 36)}{a.data.title.length > 36 ? '...' : ''}</div>
            <div class="also-card-lead">{(a.body || '').replace(/[#\n]/g, ' ').slice(0, 50)}...</div>
          </div>
        </a>
      ))}
    </div>

    <div class="also-block">
      <div class="also-title">💼 ビジネス</div>
      {rankingBusiness.length === 0 ? (
        <div class="also-empty">現在記事がありません</div>
      ) : rankingBusiness.map((a) => (
        <a class="also-card" href={`/article/${a.id}`}>
          <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} />
          <div>
            <div class="also-card-title">{a.data.title.slice(0, 36)}{a.data.title.length > 36 ? '...' : ''}</div>
            <div class="also-card-lead">{(a.body || '').replace(/[#\n]/g, ' ').slice(0, 50)}...</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

</body>
</html>