---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import profiles from '../../data/company_profiles.json';
import companiesData from '../../data/ecosystem/companies.json';
import modelsData from '../../data/ecosystem/models.json';
import productsData from '../../data/ecosystem/products.json';
import relationsData from '../../data/ecosystem/relations.json';
import sectorsData from '../../data/ecosystem/sectors.json';
import storygraphsData from '../../data/ecosystem/storygraphs.json';

export async function getStaticPaths() {
  const isArchivedArticle = (article) =>
    article.data.noindex === true ||
    article.data.indexable === false ||
    article.data.source_status === 'legacy_secondary_source';
  const allArticles = (await getCollection('articles')).filter((article) => !isArchivedArticle(article));
  const companySlugs = new Set([
    ...Object.keys(profiles),
    ...companiesData.map((company) => company.id),
  ]);

  for (const article of allArticles) {
    for (const c of article.data.companies_json ?? []) companySlugs.add(c);
  }

  return Array.from(companySlugs).map((slug) => {
    const companyArticles = allArticles
      .filter((a) => (a.data.companies_json ?? []).includes(slug))
      .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0));

    return {
      params: { slug },
      props: { slug, articles: companyArticles },
    };
  });
}

const { slug, articles } = Astro.props;
const profile = profiles[slug] ?? null;
const company = companiesData.find((c) => c.id === slug) ?? null;
const sector = sectorsData.find((s) => s.id === company?.sector);
const graph = storygraphsData.find((g) => g.company === slug);

const entityIndex = new Map([
  ...companiesData.map((item) => [item.id, { ...item, kind: 'company' }]),
  ...modelsData.map((item) => [item.id, { ...item, kind: 'model' }]),
  ...productsData.map((item) => [item.id, { ...item, kind: 'product' }]),
]);

const fallbackColor = '#5CD8CE';
const safeColor = (color) => color || fallbackColor;
const accent = safeColor(company?.brandColor || sector?.color);
const displayName = company?.name || profile?.name || slug;
const description = company?.description || profile?.description || `${displayName}のAI業界内での役割、関係企業、関連記事を整理します。`;
const logo = company?.logo;
const logoText = company?.logoText || displayName.slice(0, 2);

const getEntity = (id) => entityIndex.get(id) || { id, name: id, logoText: id.slice(0, 2), kind: 'unknown' };

const getArticleUrl = (a) => {
  const cat = a.data.category_slug || 'business';
  const s = a.data.article_slug || a.id;
  return `/article/${cat}/${s}/`;
};

const catLabels = {
  model: '基盤モデル',
  business: 'ビジネス',
  markets: '市場・株価',
  infrastructure: 'AIインフラ',
  research: '研究',
  policy: '政策',
  products: 'プロダクト',
  agents: 'AIエージェント',
  robotics: 'ロボティクス',
  'generative-ai': '生成AI',
};
const getCatLabel = (id) => catLabels[id] || id || '記事';

const relations = relationsData.filter((r) => r.source === slug || r.target === slug);
const groupIds = (filterFn, mapFn) => Array.from(new Set(relations.filter(filterFn).map(mapFn).filter(Boolean)));
const investors = groupIds((r) => r.type === 'investment' && r.target === slug, (r) => r.source);
const investments = groupIds((r) => r.type === 'investment' && r.source === slug, (r) => r.target);
const supportedBy = groupIds(
  (r) => ['semiconductor', 'accelerator', 'gpu_supply', 'cloud', 'supplier'].includes(r.type) && r.target === slug,
  (r) => r.source
);
const supports = groupIds(
  (r) => ['semiconductor', 'accelerator', 'gpu_supply', 'cloud', 'customer', 'supplier', 'platform'].includes(r.type) && r.source === slug,
  (r) => r.target
);
const partnerships = groupIds(
  (r) => ['partnership', 'distribution', 'cloud', 'gpu_supply', 'customer', 'supplier', 'platform'].includes(r.type),
  (r) => (r.source === slug ? r.target : r.source)
);
const competitors = groupIds(
  (r) => ['competitor', 'competition'].includes(r.type),
  (r) => (r.source === slug ? r.target : r.source)
);
const nodeIdsFromGroup = (group) => [
  ...(group?.nodes || []).map((node) => typeof node === 'string' ? node : node.id),
  ...((group?.subgroups || []).flatMap((subgroup) => nodeIdsFromGroup(subgroup))),
].filter(Boolean);

const graphOutputLayers = graph?.layers?.outputs || [];
const products = graphOutputLayers
  .flatMap((layer) => nodeIdsFromGroup(layer))
  .filter((id) => getEntity(id).kind !== 'company' && id !== slug)
  .slice(0, 12);

const officialUrl = profile?.website || (company?.domain ? `https://${company.domain}` : null);
const metricItems = [
  profile?.valuation && { label: '評価額・時価総額', value: profile.valuation },
  profile?.revenue && { label: '売上・ARR', value: profile.revenue },
  profile?.employees && { label: '従業員数', value: profile.employees },
  { label: '関連記事', value: `${articles.length}件` },
].filter(Boolean);
const relationGroups = [
  { title: 'この企業を支える企業', ids: supportedBy },
  { title: 'この企業が支える企業', ids: supports },
  { title: '出資者', ids: investors },
  { title: '投資先', ids: investments },
  { title: '提携・供給網', ids: partnerships },
  { title: '競合企業', ids: competitors },
];

const mapSlugOverrides = {
  nvidia: 'nvidia-empire',
  openai: 'openai-ecosystem',
  huggingface: 'open-source-ai-ecosystem',
  deepseek: 'china-ai-map',
  sakana: 'japan-ai',
};
const mapSlug = mapSlugOverrides[slug] || `${slug}-ecosystem`;
const storyFlowGroups = graph?.layers ? [
  ...(graph.layers.supply || []),
  graph.layers.center && { id: 'center', label: displayName, nodes: [graph.layers.center] },
  ...(graph.layers.outputs || []),
].filter((layer) => layer && nodeIdsFromGroup(layer).length > 0) : [];
const relatedMapLinks = Array.from(new Set([
  graph && mapSlug,
  slug === 'nvidia' && 'gpu-supply-chain',
  ...(relations.flatMap((r) => r.articles || [])
    .filter((href) => typeof href === 'string' && href.startsWith('/map/'))
    .map((href) => href.replace('/map/', '').replace('/', ''))),
].filter(Boolean))).slice(0, 4);
const supplyPosition = supportedBy.length > 0 && supports.length > 0
  ? `${displayName}は、${supportedBy.slice(0, 3).map((id) => getEntity(id).name || id).join('、')}から供給・技術基盤を受け、${supports.slice(0, 4).map((id) => getEntity(id).name || id).join('、')}へ製品・計算資源・サービスを届ける位置にあります。`
  : `${displayName}は、${sector?.name || 'AI産業'}の中で、技術、製品、資本、顧客関係を通じて周辺企業と接続するプレイヤーです。`;
const seoBody = `${displayName}はAI業界において${sector?.name || '主要領域'}に位置づけられる企業です。AI経済新聞では、${displayName}の事業概要だけでなく、供給網上の位置、主な競合、顧客・提携先、関連するStoryGraph、関連記事を横断して整理します。${supplyPosition}`;
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: displayName,
  url: officialUrl || `https://aikeizai.jp/company/${slug}/`,
  logo: logo ? (logo.startsWith('http') ? logo : `https://aikeizai.jp${logo}`) : undefined,
  description,
  sameAs: officialUrl ? [officialUrl] : undefined,
  mainEntityOfPage: `https://aikeizai.jp/company/${slug}/`,
};
const corpSchema = {
  '@context': 'https://schema.org',
  '@type': 'Corporation',
  name: displayName,
  url: officialUrl || `https://aikeizai.jp/company/${slug}/`,
  description,
  tickerSymbol: profile?.ticker,
  sameAs: officialUrl ? [officialUrl] : undefined,
  mainEntityOfPage: `https://aikeizai.jp/company/${slug}/`,
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://aikeizai.jp/' },
    { '@type': 'ListItem', position: 2, name: '企業データベース', item: 'https://aikeizai.jp/company/' },
    { '@type': 'ListItem', position: 3, name: displayName, item: `https://aikeizai.jp/company/${slug}/` },
  ],
};
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{displayName} | 企業データベース | AI経済新聞</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`https://aikeizai.jp/company/${slug}/`} />
  <meta property="og:title" content={`${displayName} | AI経済新聞`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://aikeizai.jp/ogp.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(corpSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</head>

<body>
  <Header />

  <main>
    <section class="company-hero" style={`--accent:${accent}`}>
      <div class="w hero-inner">
        <div class="identity">
          <span class="logo-frame hero-logo">
            {logo ? <img src={logo} alt={displayName} loading="eager" decoding="async" /> : logoText}
          </span>
          <div>
            <p class="eyebrow">Company Profile</p>
            <h1>{displayName}</h1>
            <p class="lead">{description}</p>
            <div class="tag-row">
              {sector && <span>{sector.name}</span>}
              {company?.country && <span>{company.country}</span>}
              {profile?.ticker && <span>{profile.ticker}</span>}
              {profile?.ceo && <span>CEO: {profile.ceo}</span>}
            </div>
          </div>
        </div>
        <div class="hero-actions">
          {officialUrl && <a class="ghost-btn" href={officialUrl} target="_blank" rel="noopener noreferrer">公式サイト →</a>}
          {graph && <a class="primary-btn" href={`/map/${mapSlug}/`}>構造ページで見る →</a>}
          <a class="ghost-btn" href="/#ai-ecosystem-map">業界マップで見る →</a>
        </div>
      </div>
    </section>

    <section class="overview">
      <div class="w metric-grid">
        {metricItems.map((item) => (
          <div class="metric-card">
            <p>{item.label}</p>
            <strong>{item.value}</strong>
          </div>
        ))}
      </div>
    </section>

    <section class="w structure-strip" aria-label="企業構造情報">
      <article>
        <p>Role</p>
        <h2>AI業界内の役割</h2>
        <span>{sector?.name || 'AI産業'}における主要プレイヤー。企業DB、関連記事、StoryGraphで関係性を追跡します。</span>
      </article>
      <article>
        <p>Supply Position</p>
        <h2>供給網上の位置</h2>
        <span>{supplyPosition}</span>
      </article>
      <article>
        <p>Competition / Customers</p>
        <h2>競合・顧客</h2>
        <span>
          {competitors.length > 0 ? `競合: ${competitors.slice(0, 4).map((id) => getEntity(id).name || id).join('、')}` : '競合関係を整理中'}
          {supports.length > 0 && ` / 関連顧客・供給先: ${supports.slice(0, 4).map((id) => getEntity(id).name || id).join('、')}`}
        </span>
      </article>
      <article>
        <p>StoryGraph</p>
        <h2>関連するStoryGraph</h2>
        <span>{graph ? `${displayName}の供給元、出力先、投資・提携関係を構造ページで確認できます。` : '関連StoryGraphを準備中です。'}</span>
      </article>
    </section>

    <div class="w layout">
      <main>
        {profile?.notable && (
          <section class="panel notable">
            <p class="eyebrow">Industry Position</p>
            <h2>AI業界内の位置づけ</h2>
            <p>{profile.notable}</p>
          </section>
        )}

        <section class="panel notable">
          <p class="eyebrow">AI Industry Role</p>
          <h2>AI業界での役割</h2>
          <p>
            {displayName}は、{sector?.name || 'AI産業'}領域で重要な位置を占める企業です。
            {supportedBy.length > 0 && ` ${supportedBy.slice(0, 3).map((id) => getEntity(id).name || id).join('、')}などの基盤に支えられています。`}
            {supports.length > 0 && ` また、${supports.slice(0, 4).map((id) => getEntity(id).name || id).join('、')}などへ技術・基盤・サービスを届けています。`}
          </p>
        </section>

        <section class="panel notable">
          <p class="eyebrow">SEO Summary</p>
          <h2>{displayName}の構造分析</h2>
          <p>{seoBody}</p>
        </section>

        {storyFlowGroups.length > 0 && (
          <section class="panel">
            <div class="panel-head">
              <div>
                <p class="eyebrow">StoryGraph Summary</p>
                <h2>構造で見る{displayName}</h2>
              </div>
              <a class="text-link" href={`/map/${mapSlug}/`}>詳しく見る →</a>
            </div>
            <div class="flow-summary">
              {storyFlowGroups.map((layer, index) => (
                <>
                  <div class="flow-group">
                    <h3>{layer.label || layer.group || displayName}</h3>
                    <div>
                      {nodeIdsFromGroup(layer).slice(0, 8).map((id) => {
                        const entity = getEntity(id);
                        return <span>{entity.name || entity.label || id}</span>;
                      })}
                    </div>
                  </div>
                  {index < storyFlowGroups.length - 1 && <span class="flow-arrow">→</span>}
                </>
              ))}
            </div>
          </section>
        )}

        <section class="panel">
          <div class="panel-head">
            <div>
              <p class="eyebrow">Relationships</p>
              <h2>関係性</h2>
            </div>
            <span>{relations.length} relations</span>
          </div>
          <div class="relation-grid">
            {relationGroups.map((group) => (
              <div class="relation-group">
                <h3>{group.title}</h3>
                {group.ids.length > 0 ? (
                  <div class="logo-list">
                    {group.ids.slice(0, 14).map((id) => {
                      const entity = getEntity(id);
                      const content = (
                        <>
                          <span class="logo-frame small">
                            {entity.logo ? (
                              <img src={entity.logo} alt={entity.name} loading="lazy" decoding="async" />
                            ) : (
                              entity.logoText || entity.name?.slice(0, 2) || id.slice(0, 2)
                            )}
                          </span>
                          <span>{entity.name || entity.label || id}</span>
                        </>
                      );
                      return entity.kind === 'company' ? (
                        <a href={`/company/${id}/`}>{content}</a>
                      ) : (
                        <span>{content}</span>
                      );
                    })}
                  </div>
                ) : (
                  <p class="empty">主要データを整理中です。</p>
                )}
              </div>
            ))}
          </div>
        </section>

        {products.length > 0 && (
          <section class="panel">
            <p class="eyebrow">Products / Models</p>
            <h2>関連モデル・サービス</h2>
            <div class="product-grid">
              {products.map((id) => {
                const entity = getEntity(id);
                return <span>{entity.name || entity.label || id}</span>;
              })}
            </div>
          </section>
        )}

        {relatedMapLinks.length > 0 && (
          <section class="panel">
            <p class="eyebrow">Related Maps</p>
            <h2>関連Map</h2>
            <div class="map-link-grid">
              {relatedMapLinks.map((map) => (
                <a href={`/map/${map}/`}>{map.replaceAll('-', ' ')}</a>
              ))}
            </div>
          </section>
        )}

        {articles.length > 0 && (
          <section class="panel">
            <p class="eyebrow">Related Articles</p>
            <h2>関連記事</h2>
            <div class="article-grid">
              {articles.slice(0, 9).map((a) => (
                <a class="article-card" href={getArticleUrl(a)}>
                  <img src={a.data.image_url || '/ogp.png'} alt={a.data.title} loading="lazy" decoding="async" />
                  <div>
                    <div class="article-meta">
                      <span>{getCatLabel(a.data.category_slug)}</span>
                      <time>{a.data.published_at || ''}</time>
                    </div>
                    <h3>{a.data.title}</h3>
                    <p>読む →</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </main>
      <Sidebar />
    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  :global(body) {
    margin: 0;
    background:
      radial-gradient(circle at 18% 0%, rgba(90,158,255,.14), transparent 34rem),
      linear-gradient(180deg, rgba(14,22,40,.9), rgba(7,9,13,0) 520px),
      #07090d;
    color: #f0f4f8;
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1440px); margin-inline: auto; }
  .company-hero {
    border-bottom: 1px solid rgba(255,255,255,.09);
    padding: 46px 0 30px;
    background: radial-gradient(circle at 22% 10%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 34rem);
  }
  .hero-inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 28px; }
  .identity { display: flex; gap: 18px; align-items: flex-start; max-width: 920px; }
  .logo-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.11);
    background: rgba(255,255,255,.055);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-weight: 900;
    color: #fff;
  }
  .logo-frame img { display: block; max-width: 72%; max-height: 72%; object-fit: contain; }
  .hero-logo { width: 82px; height: 82px; border-radius: 22px; font-size: 24px; box-shadow: 0 0 34px color-mix(in srgb, var(--accent) 20%, transparent); }
  .logo-frame.small { width: 34px; height: 34px; border-radius: 11px; font-size: 11px; flex: 0 0 auto; }
  .eyebrow {
    margin: 0;
    color: #5a9eff;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  h1 { margin: 4px 0 0; font-size: clamp(32px, 4vw, 58px); line-height: 1.08; letter-spacing: -.04em; }
  .lead { max-width: 760px; margin: 14px 0 0; color: #b7c4d8; font-size: 15px; line-height: 1.9; }
  .tag-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
  .tag-row span {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 999px;
    background: rgba(0,0,0,.22);
    padding: 6px 10px;
    color: #dbe7f5;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 9px; justify-content: flex-end; }
  .primary-btn, .ghost-btn {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 10px 15px;
    font-size: 12px;
    font-weight: 900;
    transition: transform .16s ease, background .16s ease;
  }
  .primary-btn { background: #5cd8ce; color: #07111b; }
  .ghost-btn { border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04); color: #e8eef8; }
  .primary-btn:hover, .ghost-btn:hover { transform: translateY(-2px); }
  .overview { padding: 18px 0 0; }
  .metric-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }
  .metric-card {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 14px;
    background: rgba(255,255,255,.035);
    padding: 15px 16px;
  }
  .metric-card p { margin: 0 0 7px; color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; }
  .metric-card strong { font-size: 18px; }
  .structure-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    padding-top: 12px;
  }
  .structure-strip article {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 14px;
    background: rgba(255,255,255,.035);
    padding: 15px;
  }
  .structure-strip p {
    margin: 0 0 7px;
    color: #5a9eff;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .structure-strip h2 { margin: 0 0 8px; font-size: 14px; }
  .structure-strip span { color: #b7c4d8; font-size: 12px; line-height: 1.75; }
  .layout { display: grid; grid-template-columns: minmax(0, 1fr) 340px; gap: 24px; padding: 24px 0 52px; }
  .panel {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 16px;
    background: rgba(255,255,255,.035);
    backdrop-filter: blur(14px);
    padding: 20px;
    margin-bottom: 16px;
  }
  .panel h2 { margin: 4px 0 14px; font-size: 22px; letter-spacing: -.03em; }
  .notable p:last-child { color: #b7c4d8; line-height: 1.9; margin-bottom: 0; }
  .panel-head { display: flex; justify-content: space-between; align-items: end; gap: 16px; margin-bottom: 14px; }
  .panel-head span { color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; }
  .text-link { color: #5cd8ce; font-size: 12px; font-weight: 900; white-space: nowrap; }
  .flow-summary { display: flex; align-items: stretch; gap: 10px; overflow-x: auto; padding-bottom: 4px; }
  .flow-group {
    min-width: 180px;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px;
    background: rgba(0,0,0,.18);
    padding: 12px;
  }
  .flow-group h3 { margin: 0 0 10px; color: #dbe7f5; font-size: 13px; }
  .flow-group div { display: flex; flex-wrap: wrap; gap: 6px; }
  .flow-group span {
    border: 1px solid rgba(255,255,255,.09);
