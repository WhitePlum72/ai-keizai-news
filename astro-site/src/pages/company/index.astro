---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import profiles from '../../data/company_profiles.json';

const companies = Object.values(profiles);
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI企業データベース | AI経済新聞</title>
  <meta name="description" content="OpenAI・NVIDIA・Anthropicなど主要AI企業の企業情報・ニュース・製品一覧。" />
  <link rel="canonical" href="https://aikeizai.jp/company/" />
  <meta property="og:title" content="AI企業データベース | AI経済新聞" />
  <meta property="og:type" content="website" />

  <style>
    body { margin: 0; font-family: 'Noto Sans JP', -apple-system, sans-serif; background: #f4f6f8; color: #17202a; }
    a { color: inherit; text-decoration: none; }

    .page-header { background: #003f88; color: #fff; padding: 32px 24px; text-align: center; }
    .page-header h1 { margin: 0 0 8px; font-size: 24px; font-weight: 900; }
    .page-header p { margin: 0; font-size: 14px; opacity: 0.8; }

    .container { max-width: 1200px; margin: 0 auto; padding: 24px; }

    .company-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .company-card { background: #fff; border-radius: 3px; padding: 20px; display: flex; flex-direction: column; gap: 12px; transition: transform 0.15s; }
    .company-card:hover { transform: translateY(-2px); }

    .card-header { display: flex; align-items: center; gap: 12px; }
    .card-logo { width: 48px; height: 48px; border-radius: 8px; object-fit: contain; background: #f4f6f8; border: 1px solid #e8edf2; padding: 4px; flex-shrink: 0; }
    .card-logo-fallback { width: 48px; height: 48px; border-radius: 8px; background: #003f88; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 900; color: #fff; flex-shrink: 0; }
    .card-name { font-size: 16px; font-weight: 900; color: #1a1a2e; }
    .card-meta { font-size: 11px; color: #888; }

    .card-description { font-size: 13px; color: #555; line-height: 1.7; }

    .card-kpi { display: flex; gap: 8px; flex-wrap: wrap; }
    .kpi-item { font-size: 11px; background: #f0f4fa; color: #003f88; padding: 3px 8px; border-radius: 4px; }

    .card-footer { margin-top: auto; }
    .card-link { display: inline-block; font-size: 12px; font-weight: 700; color: #003f88; padding: 6px 14px; border: 1px solid #d0ddf5; border-radius: 4px; transition: all 0.15s; }
    .card-link:hover { background: #003f88; color: #fff; }

    @media (max-width: 768px) {
      .company-grid { grid-template-columns: 1fr; }
      .container { padding: 12px; }
    }
  </style>
</head>

<body>
  <Header />

  <div class="page-header">
    <h1>🏢 AI企業データベース</h1>
    <p>主要AI企業の最新情報・ニュース・製品一覧</p>
  </div>

  <div class="container">
    <div class="company-grid">
      {companies.map(company => {
        const domain = company.website?.replace('https://', '') ?? company.slug + '.com';
        const logoUrl = `https://img.logo.dev/${domain}?token=pk_LZPEognIRoGnDKM6tw3obQ`;
        return (
          <a class="company-card" href={`/company/${company.slug}/`}>
            <div class="card-header">
              <img
                class="card-logo"
                src={logoUrl}
                alt={company.name}
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="card-logo-fallback" style="display:none">
                {company.name.charAt(0)}
              </div>
              <div>
                <div class="card-name">{company.name}</div>
                <div class="card-meta">設立 {company.founded}年 ・ {company.hq}</div>
              </div>
            </div>
            <div class="card-description">{company.description}</div>
            <div class="card-kpi">
              {company.valuation && <span class="kpi-item">{company.valuation}</span>}
              {company.ceo && <span class="kpi-item">CEO: {company.ceo}</span>}
            </div>
            <div class="card-footer">
              <span class="card-link">詳細を見る →</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <Footer />
</body>
</html>