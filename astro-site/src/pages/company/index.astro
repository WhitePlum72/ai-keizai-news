---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import profiles from '../../data/company_profiles.json';
import companiesData from '../../data/ecosystem/companies.json';
import sectorsData from '../../data/ecosystem/sectors.json';

const sectorMap = new Map(sectorsData.map((s) => [s.id, s]));
const profileMap = new Map(Object.values(profiles).map((p) => [p.slug, p]));

const companies = [...companiesData]
  .filter((company) => !company.hidden)
  .sort((a, b) => (b.trendScore || b.score || 0) - (a.trendScore || a.score || 0));

const fallbackColor = '#5CD8CE';
const safeColor = (color) => color || fallbackColor;

const categoryLabels = {
  foundation: '基盤モデル',
  infrastructure: 'AIインフラ',
  agents: 'AIエージェント',
  enterprise: 'エンタープライズAI',
  opensource: 'オープンソース',
  robotics: 'ロボティクス',
  'china-ai': '中国AI',
  'japan-ai': '日本AI',
  hardware: 'ハードウェア',
  'generative-ai': '生成AI',
};

const getSectorLabel = (id) => sectorMap.get(id)?.name || categoryLabels[id] || id || 'AI企業';
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>企業データベース | AI経済新聞</title>
  <meta name="description" content="OpenAI、NVIDIA、Anthropicなど主要AI企業の役割、関連ニュース、AI業界内での位置づけを整理した企業データベース。" />
  <link rel="canonical" href="https://aikeizai.jp/company/" />
  <meta property="og:title" content="企業データベース | AI経済新聞" />
  <meta property="og:type" content="website" />
</head>

<body>
  <Header />

  <main>
    <section class="page-hero">
      <div class="w hero-inner">
        <div>
          <p class="eyebrow">Company Intelligence</p>
          <h1>企業データベース</h1>
          <p class="hero-lead">
            AI企業を、半導体、GPU、クラウド、モデル、アプリケーション、投資関係まで含めて構造で読むための入口です。
          </p>
        </div>
        <div class="hero-stats" aria-label="データベース概要">
          <div><strong>{companies.length}</strong><span>Companies</span></div>
          <div><strong>{sectorsData.filter((s) => !s.hidden).length}</strong><span>Sectors</span></div>
        </div>
      </div>
    </section>

    <section class="company-section">
      <div class="w">
        <div class="section-head">
          <div>
            <p class="eyebrow">Directory</p>
            <h2>主要AI企業</h2>
          </div>
          <p class="section-note">企業を選ぶと詳細ページへ移動します。</p>
        </div>

        <div class="company-grid">
          {companies.map((company) => {
            const profile = profileMap.get(company.id);
            const sector = sectorMap.get(company.sector);
            const color = safeColor(company.brandColor || sector?.color);
            const description = company.description || profile?.description || 'AI業界に関連する主要企業。';
            return (
              <a class="company-card" href={`/company/${company.id}/`} style={`--accent:${color}`}>
                <div class="card-top">
                  <span class="logo-frame large">
                    {company.logo ? (
                      <img src={company.logo} alt={company.name} loading="lazy" decoding="async" />
                    ) : (
                      company.logoText || company.name.slice(0, 2)
                    )}
                  </span>
                  <div>
                    <h3>{company.name}</h3>
                    <p>{getSectorLabel(company.sector)}</p>
                  </div>
                </div>
                <p class="company-desc">{description}</p>
                <div class="chip-row">
                  {company.role && <span>{company.role}</span>}
                  {company.country && <span>{company.country}</span>}
                  {profile?.ticker && <span>{profile.ticker}</span>}
                </div>
                <div class="card-link">詳細を見る →</div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</body>
</html>

<style>
  :global(body) {
    margin: 0;
    background:
      radial-gradient(circle at 18% 0%, rgba(90,158,255,.14), transparent 34rem),
      linear-gradient(180deg, rgba(14,22,40,.9), rgba(7,9,13,0) 520px),
      #07090d;
    color: #f0f4f8;
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1440px); margin-inline: auto; }
  .page-hero { border-bottom: 1px solid rgba(255,255,255,.09); padding: 52px 0 34px; }
  .hero-inner { display: flex; justify-content: space-between; gap: 28px; align-items: end; }
  .eyebrow {
    color: #5a9eff;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  h1 { margin: 5px 0 0; font-size: clamp(30px, 4vw, 56px); line-height: 1.1; letter-spacing: -.04em; }
  .hero-lead { max-width: 720px; margin: 16px 0 0; color: #aebbd0; font-size: 15px; line-height: 1.9; }
  .hero-stats { display: flex; gap: 10px; }
  .hero-stats div {
    min-width: 118px;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 14px;
    background: rgba(255,255,255,.035);
    padding: 15px;
  }
  .hero-stats strong { display: block; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 24px; }
  .hero-stats span { color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; }
  .company-section { padding: 34px 0 56px; }
  .section-head { display: flex; justify-content: space-between; align-items: end; gap: 20px; margin-bottom: 18px; }
  .section-head h2 { margin: 3px 0 0; font-size: 24px; letter-spacing: -.03em; }
  .section-note { color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; }
  .company-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }
  .company-card {
    display: grid;
    gap: 14px;
    min-height: 250px;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 16px;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--accent) 10%, transparent), rgba(255,255,255,.025)),
      rgba(255,255,255,.035);
    padding: 18px;
    backdrop-filter: blur(14px);
    transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
  }
  .company-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 58%, white 6%);
    box-shadow: 0 18px 46px rgba(0,0,0,.24), 0 0 28px color-mix(in srgb, var(--accent) 16%, transparent);
  }
  .card-top { display: flex; align-items: center; gap: 12px; }
  .logo-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.10);
    background: rgba(255,255,255,.055);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-weight: 900;
  }
  .logo-frame.large { width: 48px; height: 48px; border-radius: 14px; font-size: 15px; }
  .logo-frame img { display: block; max-width: 70%; max-height: 70%; object-fit: contain; }
  .card-top h3 { margin: 0; color: #f8fbff; font-size: 17px; line-height: 1.25; }
  .card-top p { margin: 4px 0 0; color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; }
  .company-desc {
    margin: 0;
    color: #aebbd0;
    font-size: 13px;
    line-height: 1.8;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .chip-row { display: flex; flex-wrap: wrap; gap: 7px; margin-top: auto; }
  .chip-row span {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 999px;
    background: rgba(0,0,0,.22);
    padding: 5px 8px;
    color: #dbe7f5;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
  }
  .card-link { color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 12px; font-weight: 800; }
  @media (max-width: 1120px) {
    .company-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 760px) {
    .hero-inner, .section-head { align-items: flex-start; flex-direction: column; }
    .hero-stats { width: 100%; }
    .hero-stats div { flex: 1; }
    .company-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .company-card { min-height: 230px; padding: 15px; }
  }
  @media (max-width: 480px) {
    .company-grid { grid-template-columns: 1fr; }
  }
</style>
