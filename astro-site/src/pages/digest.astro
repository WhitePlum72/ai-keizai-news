---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const allArticles = (await getCollection('articles')).filter((article) =>
  article.data.noindex !== true &&
  article.data.indexable !== false &&
  article.data.source_status !== 'legacy_secondary_source'
);

const digestArticles = allArticles
  .filter((article) => article.data.is_digest === true)
  .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0));

const popularArticles = allArticles
  .filter((article) => !article.data.is_digest)
  .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0))
  .slice(0, 12);

const articles = digestArticles.length > 0 ? digestArticles : popularArticles;

const getArticleUrl = (article) => {
  const category = article.data.category_slug || 'business';
  const slug = article.data.article_slug || article.id;
  return `/article/${category}/${slug}/`;
};

const getLead = (entry) =>
  entry.data.description ||
  entry.data.meta_description ||
  ((entry.body || '').replace(/[#\n]/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 90) + '...');
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AI業界ダイジェスト | AI経済新聞</title>
  <meta name="description" content="AI業界の重要ニュースを、企業関係・供給網・市場構造の観点から整理したダイジェストです。" />
  <link rel="canonical" href="https://aikeizai.jp/digest/" />
</head>
<body>
  <Header />
  <main>
    <section class="digest-hero">
      <div class="w">
        <p class="eyebrow">AI Industry Digest</p>
        <h1>AI業界ダイジェスト</h1>
        <p class="lead">AI企業、半導体、クラウド、モデル、政策の動きをまとめて読み、業界構造の変化を短時間で把握できます。</p>
      </div>
    </section>

    <section class="w digest-grid" aria-label="ダイジェスト記事">
      {articles.map((article) => (
        <a class="digest-card" href={getArticleUrl(article)}>
          <span>{article.data.category || article.data.category_slug || '記事'}</span>
          <h2>{article.data.title}</h2>
          <p>{getLead(article)}</p>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  :global(body) {
    margin: 0;
    background: #07090d;
    color: #f3f7fb;
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1200px); margin-inline: auto; }
  .digest-hero {
    padding: 56px 0 28px;
    border-bottom: 1px solid rgba(255,255,255,.09);
    background:
      radial-gradient(circle at 20% 0%, rgba(90,158,255,.16), transparent 32rem),
      linear-gradient(180deg, rgba(12,18,32,.92), rgba(7,9,13,0));
  }
  .eyebrow {
    margin: 0;
    color: #5cd8ce;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .16em;
    text-transform: uppercase;
  }
  h1 {
    margin: 8px 0 0;
    font-size: clamp(34px, 5vw, 58px);
    line-height: 1.05;
    letter-spacing: -.05em;
  }
  .lead {
    max-width: 780px;
    margin: 14px 0 0;
    color: #b8c4d7;
    line-height: 1.9;
  }
  .digest-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    padding: 28px 0 56px;
  }
  .digest-card {
    display: grid;
    gap: 10px;
    min-height: 190px;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 16px;
    background: rgba(255,255,255,.035);
    backdrop-filter: blur(14px);
    padding: 18px;
    transition: transform .16s ease, border-color .16s ease, background .16s ease;
  }
  .digest-card:hover {
    transform: translateY(-2px);
    border-color: rgba(92,216,206,.38);
    background: rgba(92,216,206,.055);
  }
  .digest-card span {
    color: #5a9eff;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .digest-card h2 {
    margin: 0;
    font-size: 17px;
    line-height: 1.55;
  }
  .digest-card p {
    margin: 0;
    color: #aebbd0;
    line-height: 1.75;
    font-size: 13px;
  }
  @media (max-width: 900px) {
    .digest-grid { grid-template-columns: 1fr; }
  }
</style>
