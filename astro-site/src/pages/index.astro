<script>
// ================================================================
// 3D GLOBE (Three.js)
// ================================================================


// ================================================================
// COMPANY CARDS
// ================================================================
(function() {
  const cards  = document.querySelectorAll('.co-card');
  const detail = document.getElementById('co-detail');
  const closeBtn = document.getElementById('co-detail-close');

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const name  = card.dataset.name;
      const sub   = card.dataset.sub;
      const desc  = card.dataset.desc;
      const color = card.dataset.color;
      const url   = card.dataset.url;
      const slug  = card.dataset.slug;
      const logo  = card.querySelector('.co-logo')?.innerHTML || '';

      document.getElementById('co-detail-logo').innerHTML = logo;
      document.getElementById('co-detail-name').textContent = name;
      document.getElementById('co-detail-name').style.color = color;
      document.getElementById('co-detail-sub').textContent  = sub;
      document.getElementById('co-detail-desc').textContent = desc;
      const link = document.getElementById('co-detail-link');
      link.href = url;
      link.style.color = color;

      // Highlight selected
      cards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      card.style.setProperty('--active-color', color);

      detail.style.display = 'block';
      detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  closeBtn?.addEventListener('click', () => {
    detail.style.display = 'none';
    cards.forEach(c => c.classList.remove('active'));
  });
})();
</script>

