---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';

const allArticles = await getCollection('articles');
const sorted = [...allArticles].sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0));

const hero = sorted[0];

const breakingIds = new Set([hero?.id]);
const breaking = sorted.filter(a => !breakingIds.has(a.id)).slice(0, 8);
breaking.forEach(a => breakingIds.add(a.id));

const official = allArticles
  .filter(a => a.data.source_label && !breakingIds.has(a.id))
  .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0))
  .slice(0, 4);
official.forEach(a => breakingIds.add(a.id));

const byCategory = (slug, limit = 4) =>
  allArticles
    .filter(a => a.data.category_slug === slug && !breakingIds.has(a.id))
    .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0))
    .slice(0, limit);

const catSections = [
  { slug: "model",          label: "モデル",      emoji: "🤖" },
  { slug: "business",       label: "ビジネス",    emoji: "💼" },
  { slug: "markets",        label: "AI関連株",    emoji: "📈" },
  { slug: "infrastructure", label: "インフラ",    emoji: "🖥️" },
  { slug: "research",       label: "研究",        emoji: "🔬" },
  { slug: "policy",         label: "政策",        emoji: "⚖️" },
  { slug: "products",       label: "プロダクト",  emoji: "📦" },
].map(cat => ({ ...cat, articles: byCategory(cat.slug, 4) }))
 .filter(cat => cat.articles.length > 0);

const latestExcluded = new Set([...breakingIds]);
const latest = [...allArticles]
  .sort((a, b) => (b.data.published_at || "").localeCompare(a.data.published_at || ""))
  .filter(a => !latestExcluded.has(a.id))
  .slice(0, 10);

const getArticleUrl = (article) => {
  const cat = article.data.category_slug || "business";
  const slug = article.data.article_slug || article.id;
  return `/article/${cat}/${slug}/`;
};

const getCatLabel = (slug) => ({
  model: "モデル", business: "ビジネス", markets: "AI関連株",
  infrastructure: "インフラ", research: "研究", policy: "政策", products: "プロダクト",
}[slug] || slug);

const getCatColor = (slug) => ({
  model: "#003f88", business: "#c0392b", markets: "#b7770d",
  infrastructure: "#2e7d32", research: "#6a1b9a", policy: "#00695c", products: "#0277bd",
}[slug] || "#555");

const getLead = (entry) =>
  ((entry.body || "").replace(/[#*`\[\]\n]/g, " ").replace(/\s+/g, " ").trim().slice(0, 120)) + "…";

const formatDate = (str) => {
  if (!str) return "";
  const d = new Date(str);
  if (isNaN(d)) return str;
  return d.toLocaleDateString("ja-JP", { month: "numeric", day: "numeric" });
};

const TOPICS = [
  "openai","nvidia","anthropic","google","microsoft",
  "meta","amd","amazon","llm","reasoning",
  "agents","gpu","datacenter","semiconductor","agi","multimodal","coding-agent"
];

const COMPANIES = [
  { name: "OpenAI",    slug: "openai" },
  { name: "NVIDIA",    slug: "nvidia" },
  { name: "Anthropic", slug: "anthropic" },
  { name: "Google",    slug: "google" },
  { name: "Microsoft", slug: "microsoft" },
  { name: "Meta",      slug: "meta" },
  { name: "Amazon",    slug: "amazon" },
  { name: "xAI",       slug: "xai" },
  { name: "AMD",       slug: "amd" },
  { name: "TSMC",      slug: "tsmc" },
];

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AI経済新聞",
  "url": "https://aikeizai.jp/",
  "description": "AIと経済の最新ニュースを毎日3回配信",
  "inLanguage": "ja",
  "publisher": {
    "@type": "Organization",
    "name": "AI経済新聞",
    "url": "https://aikeizai.jp/"
  }
};

const newsMediaSchema = {
  "@context": "https://schema.org",
  "@type": "NewsMediaOrganization",
  "name": "AI経済新聞",
  "url": "https://aikeizai.jp/",
  "logo": {
    "@type": "ImageObject",
    "url": "https://aikeizai.jp/logo.png",
    "width": 600,
    "height": 60
  },
  "sameAs": ["https://x.com/aikeizai_jp"],
  "foundingDate": "2026",
  "inLanguage": "ja",
  "publishingPrinciples": "https://aikeizai.jp/about/",
  "masthead": "https://aikeizai.jp/about/",
  "diversityPolicy": "https://aikeizai.jp/about/",
  "ethicsPolicy": "https://aikeizai.jp/about/",
  "correctionsPolicy": "https://aikeizai.jp/about/",
  "actionableFeedbackPolicy": "https://aikeizai.jp/about/",
  "verificationFactCheckingPolicy": "https://aikeizai.jp/about/",
  "noBylinesPolicy": "https://aikeizai.jp/about/",
  "coverageStartsAt": "2026-01-01T00:00:00+09:00",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "editorial",
    "email": "info@umebase.com"
  },
  "brand": [
    { "@type": "Brand", "name": "AI経済新聞", "url": "https://aikeizai.jp/" }
  ]
};
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
