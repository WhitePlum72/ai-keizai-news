---
/**
 * AI経済新聞 preview.astro
 * URL: http://localhost:4321/preview/
 */
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LiveAIEcosystemNetwork from '../components/LiveAIEcosystemNetwork';


const allArticles = await getCollection('articles');
const sorted = [...allArticles].sort(
  (a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0)
);

const hero    = sorted[0];
const usedIds = new Set([hero?.id]);

const breaking = sorted.filter(a => !usedIds.has(a.id)).slice(0, 8);
breaking.forEach(a => usedIds.add(a.id));

const official = allArticles
  .filter(a => a.data.source_label && !usedIds.has(a.id))
  .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0))
  .slice(0, 6);
official.forEach(a => usedIds.add(a.id));

const byCategory = (slug, limit = 4) =>
  allArticles
    .filter(a => a.data.category_slug === slug && !usedIds.has(a.id))
    .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0))
    .slice(0, limit);

const catSections = [
  { slug: 'model',          label: 'モデル',     url: '/model/'          },
  { slug: 'business',       label: 'ビジネス',   url: '/business/'       },
  { slug: 'markets',        label: 'AI関連株',   url: '/markets/'        },
  { slug: 'infrastructure', label: 'インフラ',   url: '/infrastructure/' },
  { slug: 'research',       label: '研究',       url: '/research/'       },
  { slug: 'policy',         label: '政策',       url: '/policy/'         },
  { slug: 'products',       label: 'プロダクト', url: '/products/'       },
].map(c => ({ ...c, articles: byCategory(c.slug, 4) }))
 .filter(c => c.articles.length > 0);

const latestExcluded = new Set([...usedIds]);
const latest = [...allArticles]
  .sort((a, b) => (b.data.published_at || '').localeCompare(a.data.published_at || ''))
  .filter(a => !latestExcluded.has(a.id))
  .slice(0, 11);
const featuredLatest = latest.slice(0, 2);
const compactLatest = latest.slice(2, 11);

const getUrl = (a) =>
  `/article/${a.data.category_slug || 'business'}/${a.data.article_slug || a.id}/`;

const CAT_LABEL = {
  model:'モデル', business:'ビジネス', markets:'AI関連株',
  infrastructure:'インフラ', research:'研究', policy:'政策', products:'プロダクト',
};
const getCatLabel = (s) => CAT_LABEL[s] || s;

const CAT_COLOR = {
  model:'#4d8ef0', business:'#e05252', markets:'#c49a20',
  infrastructure:'#2fa86e', research:'#9b6dea', policy:'#0ea5c4', products:'#4299c4',
};
const getCatColor = (s) => CAT_COLOR[s] || '#6b7280';

const getLead = (e) =>
  ((e.body || '').replace(/[#*`\[\]\n]/g,' ').replace(/\s+/g,' ').trim().slice(0, 200));
const getArticleLead = (e) =>
  (e.data.description || e.data.summary || e.data.excerpt || getLead(e)).replace(/\s+/g, ' ').trim();

const fmtDate = (s) => {
  if (!s) return '';
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toLocaleDateString('ja-JP', { month:'numeric', day:'numeric' });
};
const fmtFull = (s) => {
  if (!s) return '';
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toLocaleDateString('ja-JP', { year:'numeric', month:'long', day:'numeric' });
};

// Hero summary: 必ず3つに分割
const buildSummary = (entry) => {
  if (!entry) return ['', '', ''];
  const text = getLead(entry);
  const sentences = text.split(/。|．/).map(s => s.trim()).filter(s => s.length > 8);
  while (sentences.length < 3) sentences.push('詳細は記事本文をご覧ください');
  return sentences.slice(0, 3).map(s => s + '。');
};
const heroSummary = buildSummary(hero);

const TICKER = [
  {name:'NVDA',val:'$1,120',chg:'+2.4%',up:true},
  {name:'AMD', val:'$162', chg:'-1.0%',up:false},
  {name:'MSFT',val:'$415', chg:'+0.9%',up:true},
  {name:'GOOG',val:'$178', chg:'+1.4%',up:true},
  {name:'META',val:'$564', chg:'+2.1%',up:true},
  {name:'SOX', val:'5,312',chg:'+0.8%',up:true},
  {name:'H100',val:'$2.10',chg:'-5.4%',up:false},
  {name:'ARR', val:'$4.2B',chg:'推定', up:true},
];

const PULSES = [
  {label:'NVIDIA GPU需給', value:'逼迫',   sub:'H100在庫不足',        tone:'warn', icon:'⚡'},
  {label:'OpenAI 推定ARR', value:'$4.2B',  sub:'前年比 +180%',        tone:'up',   icon:'📈'},
  {label:'H100 スポット',  value:'$2.10',  sub:'1時間（推定）',        tone:'dn',   icon:'💻'},
  {label:'CoreWeave 調達', value:'$12B',   sub:'2026年累計',          tone:'up',   icon:'💰'},
  {label:'DC投資額',       value:'$248B',  sub:'2026年世界推計',      tone:'up',   icon:'🏗️'},
  {label:'AI関連ETF',      value:'+1.1%',  sub:'前日比',              tone:'up',   icon:'📊'},
  {label:'推論コスト',     value:'急落中', sub:'GPT-4o比 -60%',       tone:'up',   icon:'🔽'},
  {label:'電力制約',       value:'深刻化', sub:'北米DC新設遅延',      tone:'warn', icon:'⚠️'},
];

const DASHBOARD = [
  {label:'NVIDIA株価',  value:'1,120', unit:'USD', delta:'+2.4%', up:true },
  {label:'SOX指数',     value:'5,312', unit:'pt',  delta:'+0.8%', up:true },
  {label:'H100価格',    value:'28,500',unit:'USD', delta:'-3.0%', up:false},
  {label:'GPU需給',     value:'86',    unit:'/100',delta:'逼迫',  up:false},
  {label:'DC投資額',    value:'248B',  unit:'USD', delta:'+18%',  up:true },
  {label:'OpenAI ARR', value:'4.2B',  unit:'USD', delta:'+成長', up:true },
  {label:'AI ETF',     value:'142.6', unit:'idx', delta:'+1.1%', up:true },
  {label:'推論コスト',  value:'-60%',  unit:'YoY', delta:'低下',  up:true },
];

const TRENDS = [
  {label:'AGI',          slug:'agi'},
  {label:'Reasoning',    slug:'reasoning'},
  {label:'Agents',       slug:'agents'},
  {label:'GPU',          slug:'gpu'},
  {label:'Multimodal',   slug:'multimodal'},
  {label:'Inference',    slug:'reasoning'},
  {label:'Datacenter',   slug:'datacenter'},
  {label:'HBM',          slug:'semiconductor'},
  {label:'Sovereign AI', slug:'policy'},
  {label:'AI Act',       slug:'policy'},
  {label:'Robotics',     slug:'agi'},
  {label:'RAG',          slug:'research'},
  {label:'Semiconductor',slug:'semiconductor'},
  {label:'OpenAI',       slug:'openai'},
  {label:'NVIDIA',       slug:'nvidia'},
];

// 企業ロゴデータ（SVGインライン）
const COMPANIES = [
  {
    name:'OpenAI', slug:'openai', sub:'GPT-4o / o3',
    desc:'大規模言語モデルのパイオニア。ChatGPT、GPT-4o、o3を開発。',
    color:'#10a37f',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="18" fill="#10a37f" fill-opacity=".15" stroke="#10a37f" stroke-width="1.5"/><text x="20" y="26" text-anchor="middle" font-size="14" font-weight="900" fill="#10a37f" font-family="serif">O</text></svg>`,
  },
  {
    name:'NVIDIA', slug:'nvidia', sub:'H100 / B200 / CUDA',
    desc:'AIアクセラレータ市場を独占。H100、B200、CUDAエコシステム。',
    color:'#76b900',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="36" height="36" rx="4" fill="#76b900" fill-opacity=".15" stroke="#76b900" stroke-width="1.5"/><text x="20" y="26" text-anchor="middle" font-size="12" font-weight="900" fill="#76b900" font-family="sans-serif">NV</text></svg>`,
  },
  {
    name:'Anthropic', slug:'anthropic', sub:'Claude 3.x',
    desc:'Constitutional AIを開発。Claude 3シリーズで企業市場を席巻。',
    color:'#d97706',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="18" fill="#d97706" fill-opacity=".12" stroke="#d97706" stroke-width="1.5"/><text x="20" y="26" text-anchor="middle" font-size="14" font-weight="900" fill="#d97706" font-family="sans-serif">A</text></svg>`,
  },
  {
    name:'Google', slug:'google', sub:'Gemini 2.0 / TPU',
    desc:'Gemini、DeepMind、TPUでAI全領域をカバー。',
    color:'#4285f4',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="18" fill="#4285f4" fill-opacity=".1" stroke="#4285f4" stroke-width="1.5"/><text x="20" y="26" text-anchor="middle" font-size="14" font-weight="900" fill="#4285f4" font-family="sans-serif">G</text></svg>`,
  },
  {
    name:'Meta', slug:'meta', sub:'Llama 4 / OSSモデル',
    desc:'Llama 4をオープンソースで公開。AI研究をリード。',
    color:'#0081fb',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="36" height="36" rx="6" fill="#0081fb" fill-opacity=".1" stroke="#0081fb" stroke-width="1.5"/><text x="20" y="26" text-anchor="middle" font-size="12" font-weight="900" fill="#0081fb" font-family="sans-serif">Meta</text></svg>`,
  },
  {
    name:'Microsoft', slug:'microsoft', sub:'Azure AI / Copilot',
    desc:'OpenAIへの投資と統合でAI商業化を主導。Azure AIが急成長。',
    color:'#00a4ef',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="6" width="12" height="12" fill="#f25022"/><rect x="22" y="6" width="12" height="12" fill="#00a4ef"/><rect x="6" y="22" width="12" height="12" fill="#ffb900"/><rect x="22" y="22" width="12" height="12" fill="#7fba00"/></svg>`,
  },
  {
    name:'AMD', slug:'amd', sub:'MI300X / ROCm',
    desc:'NVIDIAに次ぐGPU勢力。MI300XでAI学習市場に参入。',
    color:'#ed1c24',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="36" height="36" rx="4" fill="#ed1c24" fill-opacity=".1" stroke="#ed1c24" stroke-width="1.5"/><text x="20" y="27" text-anchor="middle" font-size="12" font-weight="900" fill="#ed1c24" font-family="sans-serif">AMD</text></svg>`,
  },
  {
    name:'TSMC', slug:'tsmc', sub:'2nm / CoWoS',
    desc:'世界最先端半導体製造。2nm量産とCoWoSでAIチップを支える。',
    color:'#5c9ecf',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><polygon points="20,2 38,11 38,29 20,38 2,29 2,11" fill="#5c9ecf" fill-opacity=".1" stroke="#5c9ecf" stroke-width="1.5"/><text x="20" y="26" text-anchor="middle" font-size="9" font-weight="900" fill="#5c9ecf" font-family="sans-serif">TSMC</text></svg>`,
  },
  {
    name:'Amazon', slug:'amazon', sub:'AWS Bedrock / Trainium',
    desc:'AWS Bedrockでエンタープライズ向けAI基盤を提供。Trainium開発。',
    color:'#ff9900',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="36" height="36" rx="4" fill="#ff9900" fill-opacity=".1" stroke="#ff9900" stroke-width="1.5"/><text x="20" y="27" text-anchor="middle" font-size="11" font-weight="900" fill="#ff9900" font-family="sans-serif">AWS</text></svg>`,
  },
  {
    name:'xAI', slug:'xai', sub:'Grok / Colossus',
    desc:'Grokを開発。Colossusクラスターで急速に計算資源を拡張中。',
    color:'#e5e7eb',
    svg:`<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="18" fill="#e5e7eb" fill-opacity=".08" stroke="#e5e7eb" stroke-width="1.5"/><text x="20" y="26" text-anchor="middle" font-size="14" font-weight="900" fill="#e5e7eb" font-family="sans-serif">xAI</text></svg>`,
  },
];

const jsonLd = [
  {'@context':'https://schema.org','@type':'WebSite',name:'AI経済新聞',url:'https://aikeizai.jp/'},
  {'@context':'https://schema.org','@type':'NewsMediaOrganization',name:'AI経済新聞',url:'https://aikeizai.jp/',publishingPrinciples:'https://aikeizai.jp/about/'},
];
---

<!doctype html>
<html lang="ja">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>AI経済新聞 | AI産業OS — AI・半導体・市場・政策を構造で読む</title>
<meta name="description" content="AI・半導体・市場・インフラ・政策を構造で読む日本語AI業界インテリジェンスメディア。一次情報特化。毎日3回更新。"/>
<link rel="canonical" href="https://aikeizai.jp/"/>
<meta property="og:type" content="website"/>
<meta property="og:title" content="AI経済新聞 | AI産業OS"/>
<meta property="og:description" content="AI・半導体・市場・インフラ・政策を構造で読む日本語AI業界インテリジェンスメディア。"/>
<meta property="og:image" content="https://aikeizai.jp/ogp.png"/>
<meta name="twitter:card" content="summary_large_image"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@700;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<link rel="alternate" type="application/rss+xml" href="https://aikeizai.jp/rss.xml"/>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}/>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-R8C9ET314H"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-R8C9ET314H');</script>
<!-- Three.js for Globe -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>

<!-- TICKER -->
<div class="ticker-bar" aria-hidden="true">
  <span class="ticker-label">MARKET</span>
  <div class="ticker-scroll">
    <div class="ticker-track">
      {[...TICKER,...TICKER].map(t=>(
        <span class="t-item">
          <span class="t-name">{t.name}</span>
          <span class="t-val">{t.val}</span>
          <span class={t.up?'t-up':'t-dn'}>{t.chg}</span>
        </span>
      ))}
    </div>
  </div>
</div>

<!-- HEADER -->
<header class="site-header">
  <div class="w">
    <a class="brand" href="/"><span class="brand-mark">AI</span><span class="brand-name">AI経済新聞</span></a>
    <nav class="gnav" aria-label="メインナビ">
      <a href="/markets/">Markets</a>
      <a href="/company/">Companies</a>
      <a href="/model/">Models</a>
      <a href="/infrastructure/">Infra</a>
      <a href="/policy/">Policy</a>
      <a href="/research/">Research</a>
    </nav>
    <div class="hright"><a class="hbtn" href="/about/">About</a></div>
  </div>
</header>
<h1 class="sr-only">AI経済新聞 — AI産業OS</h1>

<main>

<!-- ================================================================
     §1 MARKET PULSE
     ================================================================ -->
<section class="section pulse-section" aria-labelledby="pulse-hd">
  <div class="w">
    <div class="sec-head compact">
      <div class="sec-left">
        <span class="eyebrow">Market Pulse</span>
        <h2 class="sec-title" id="pulse-hd">AI市場の現在地</h2>
      </div>
      <span class="sec-note">参考値 · 随時更新</span>
    </div>
    <div class="pulse-scroll">
      <div class="pulse-grid">
        {PULSES.map(p=>(
          <div class={`pulse-card tone-${p.tone}`}>
            <div class="pulse-icon">{p.icon}</div>
            <div class="pulse-label">{p.label}</div>
            <div class="pulse-value">{p.value}</div>
            <div class="pulse-sub">{p.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ================================================================
     §2 最新記事 — 画像カード2件 + タイトル一覧
     ================================================================ -->
<section class="section" aria-labelledby="latest-title">
  <div class="w">
    <div class="section-head">
      <div>
        <p class="eyebrow">Latest Intelligence</p>
        <h2 id="latest-title">最新記事</h2>
      </div>
      <a class="pill" href="/articles">すべての記事</a>
    </div>
    <div class="article-grid">
      {featuredLatest.map(article => (
        <article class="article-card">
          <a href={getUrl(article)}>
            {article.data.image_url
              ? <img src={article.data.image_url} alt={article.data.title} width="640" height="400" loading="lazy" decoding="async"/>
              : <div class="article-img-ph">◈</div>
            }
            <div class="article-body">
              <div class="article-meta">
                <span class="category" style={`background:${getCatColor(article.data.category_slug)}`}>
                  {getCatLabel(article.data.category_slug)}
                  
                </span>
                <span class="pill">{article.data.source}</span>
                {(article.data.buzz_score||0) >= 60
                  ? <span class="importance high">重要</span>
                  : (article.data.buzz_score||0) >= 40
                  ? <span class="importance med">注目</span>
                  : null
                }
                
                {article.data.source_label && <span class="source-badge">一次情報</span>}
              </div>
              <h3>{article.data.title}</h3>
              <p class="article-lead">{getArticleLead(article)}</p>
              
              <p class="article-date">{fmtDate(article.data.published_at)}</p>
            </div>
          </a>
        </article>
      ))}

      <aside class="latest-list-card" aria-label="その他の最新記事">
        <div class="latest-list-head">
          <div>
            <p class="eyebrow">More Stories</p>
            <h3>さらに読む</h3>
          </div>
          <span>最新記事</span>
        </div>
        <div class="latest-list">
          {compactLatest.map(article => (
            <a class="latest-list-item" href={getUrl(article)}>
              <span class="latest-list-meta">
                <span style={`color:${getCatColor(article.data.category_slug)}`}>
                  {getCatLabel(article.data.category_slug)}
                </span>
                <time>{fmtDate(article.data.published_at)}</time>
              </span>
              <strong>{article.data.title}</strong>
            </a>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- ================================================================
     §3 HERO — 注目の最重要ニュース（なぜ重要か + 3セル要約）
     ================================================================ -->
{hero && (
  <section class="section hero-section" aria-labelledby="hero-hd">
    <div class="w">
      <div class="section-head">
        <div>
          <p class="eyebrow">Top Story</p>
          <h2 id="hero-hd">注目の最重要ニュース</h2>
        </div>
      </div>
      <div class="hero-grid">
        <!-- 左: コピー -->
        <div class="hero-copy">
          <div class="hero-tags">
            <span class="tag tag-cat" style={`background:${getCatColor(hero.data.category_slug)}`}>
              {getCatLabel(hero.data.category_slug)}
            </span>
            {hero.data.source_label && <span class="tag tag-primary">{hero.data.source_label}</span>}
            {(hero.data.buzz_score||0) >= 50 && <span class="tag tag-hot">🔥 注目</span>}
          </div>

          <h2 class="hero-title">
            <a href={getUrl(hero)}>{hero.data.title}</a>
          </h2>

          <!-- 3セル要約（必ず3つ）-->
          <div class="hero-summary">
            {heroSummary.map(s => <p>{s}</p>)}
          </div>

          <!-- なぜ重要か -->
          <div class="why-box">
          <div class="impact-box">
  <div class="impact-head">
    <span class="impact-live"></span>
    <span>MARKET IMPACT</span>
  </div>

  <ul class="impact-list">
    <li>GPU需給への影響</li>
    <li>AI関連株への波及</li>
    <li>データセンター投資加速</li>
  </ul>
</div>
            <span class="eyebrow">なぜ重要か</span>
            <p>
              {hero.data.source_label
                ? `${hero.data.source}が公式に発表した一次情報です。`
                : `${hero.data.source}が報じた、AI産業の構造変化に直結するニュースです。`
              }
              AI業界の投資家・経営者・エンジニアが注目すべき動向として、
              buzz_score {hero.data.buzz_score || 0} の高関連度記事として選出されました。
            </p>
          </div>

          <div class="hero-footer">
            <span class="hero-src">{hero.data.source}</span>
            <time class="hero-date">{fmtFull(hero.data.published_at)}</time>
            <a class="hero-cta" href={getUrl(hero)}>続きを読む →</a>
          </div>
        </div>

        <!-- 右: 画像 -->
        <figure class="hero-media">
          {hero.data.image_url
            ? <img src={hero.data.image_url} alt={hero.data.title}
                loading="eager" fetchpriority="high" decoding="async" width="900" height="600"/>
            : <div class="hero-ph-lg">◈</div>
          }
          <div class="terminal-strip">
            <span>GPU: TIGHT</span>
            <span>CAPEX: ↑</span>
            <span>INFERENCE: ↑</span>
            <span>POLICY: ACT</span>
          </div>
        </figure>
      </div>
    </div>
  </section>
)}


<!-- ================================================================
     §4 AI INDUSTRY NETWORK — Semantic Neural Sphere
     ================================================================ -->
<LiveAIEcosystemNetwork client:only="react" />

<!-- ================================================================
     §5 Breaking
     ================================================================ -->
