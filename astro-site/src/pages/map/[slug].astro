---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import companiesData from '../../data/ecosystem/companies.json';
import modelsData from '../../data/ecosystem/models.json';
import productsData from '../../data/ecosystem/products.json';
import relationsData from '../../data/ecosystem/relations.json';
import storygraphsData from '../../data/ecosystem/storygraphs.json';

export async function getStaticPaths() {
  const slugOverrides = {
    nvidia: ['nvidia-empire', 'gpu-supply-chain'],
    openai: ['openai-ecosystem'],
    langchain: ['ai-agent-wars'],
    huggingface: ['open-source-ai-ecosystem'],
    deepseek: ['china-ai-map'],
    'sakana-ai': ['japan-ai'],
  };

  return storygraphsData.flatMap((graph) => {
    const slugs = Array.from(new Set([`${graph.company}-ecosystem`, ...(slugOverrides[graph.company] || [])]));
    return slugs.map((slug) => ({ params: { slug }, props: { graph, slug } }));
  });
}

const { graph, slug } = Astro.props;
const isArchivedArticle = (article) =>
  article.data.noindex === true ||
  article.data.indexable === false ||
  article.data.source_status === 'legacy_secondary_source';
const allArticles = (await getCollection('articles')).filter((article) => !isArchivedArticle(article));

const entities = new Map([
  ...companiesData.map((item) => [item.id, { ...item, kind: 'company' }]),
  ...modelsData.map((item) => [item.id, { ...item, kind: 'model' }]),
  ...productsData.map((item) => [item.id, { ...item, kind: 'product' }]),
]);

const company = entities.get(graph.company);
const displayName = company?.name || graph.company;
const titleBySlug = {
  'nvidia-empire': 'NVIDIA Empire',
  'gpu-supply-chain': 'GPU\u4f9b\u7d66\u7db2',
  'openai-ecosystem': 'OpenAI Ecosystem',
  'ai-agent-wars': 'AI Agent Wars',
  'china-ai-map': '\u4e2d\u56fdAI\u52e2\u529b\u56f3',
  'japan-ai': '\u65e5\u672cAI\u30a8\u30b3\u30b7\u30b9\u30c6\u30e0',
  'open-source-ai-ecosystem': 'Open Source AI Ecosystem',
};
const pageTitle = titleBySlug[slug] || graph.title || `${displayName} Ecosystem`;
const pageDescription = graph.summary || `${displayName}を中心に、供給元、技術基盤、製品、顧客、競合関係を整理したAI業界構造ページです。`;
const canonicalUrl = `https://aikeizai.jp/map/${slug}/`;

const getEntity = (id) => entities.get(id) || { id, name: id, logoText: id.slice(0, 2), kind: 'unknown' };
const nodeIdsFromGroup = (group) => [
  ...(group?.nodes || []).map((node) => typeof node === 'string' ? node : node.id),
  ...((group?.subgroups || []).flatMap((subgroup) => nodeIdsFromGroup(subgroup))),
].filter(Boolean);

const layers = graph.layers ? [
  ...(graph.layers.supply || []),
  graph.layers.center && { id: 'center', label: displayName, nodes: [graph.layers.center] },
  ...(graph.layers.outputs || []),
].filter((layer) => layer && nodeIdsFromGroup(layer).length > 0) : [];
const layerEntities = layers.map((layer) => ({
  label: layer.label || layer.group || displayName,
  ids: nodeIdsFromGroup(layer),
}));
const allLayerEntityIds = Array.from(new Set(layerEntities.flatMap((layer) => layer.ids)));
const relatedCompanies = allLayerEntityIds
  .map((id) => getEntity(id))
  .filter((entity) => entity.kind === 'company')
  .slice(0, 18);

const bottomGroups = graph.bottomGroups || {};
const bottomLabels = {
  investors: '\u51fa\u8cc7\u8005',
  investments: '\u6295\u8cc7\u5148',
  investment: '\u51fa\u8cc7',
  partnership: '\u63d0\u643a',
  distribution: '\u63d0\u4f9b\u30c1\u30e3\u30cd\u30eb',
  competitor: '\u7af6\u5408\u4f01\u696d',
  customer: '\u4e3b\u8981\u9867\u5ba2',
  supplier: '\u4f9b\u7d66\u5143',
  ecosystem: '\u30a8\u30b3\u30b7\u30b9\u30c6\u30e0',
  ownership: '\u6240\u6709\u30fb\u89aa\u4f1a\u793e',
};
const bottomEntries = Object.entries(bottomGroups)
  .map(([key, ids]) => ({ key, label: bottomLabels[key] || key, ids: Array.isArray(ids) ? ids : [] }))
  .filter((entry) => entry.ids.length > 0 && !['customer', 'supplier'].includes(entry.key));

const relatedArticles = allArticles
  .filter((article) => (article.data.companies_json || []).includes(graph.company))
  .sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0))
  .slice(0, 6);
const graphArticles = Array.isArray(graph.articles) ? graph.articles.slice(0, 4) : [];
const getArticleUrl = (article) => `/article/${article.data.category_slug || 'business'}/${article.data.article_slug || article.id}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: pageTitle,
      description: pageDescription,
      url: canonicalUrl,
      inLanguage: 'ja',
      about: displayName,
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: layers.map((layer, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: layer.label || layer.group || `Layer ${index + 1}`,
          item: nodeIdsFromGroup(layer).map((id) => getEntity(id).name || id).join(', '),
        })),
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://aikeizai.jp/' },
        { '@type': 'ListItem', position: 2, name: 'StoryGraph', item: 'https://aikeizai.jp/storygraph/' },
        { '@type': 'ListItem', position: 3, name: pageTitle, item: canonicalUrl },
      ],
    },
    {
      '@type': 'ItemList',
      name: `${pageTitle}の関連企業`,
      itemListElement: relatedCompanies.map((entity, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: entity.name || entity.id,
        url: `https://aikeizai.jp/company/${entity.id}/`,
      })),
    },
  ],
};
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle} | AI業界マップ | AI経済新聞</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${pageTitle} | AI経済新聞`} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content="https://aikeizai.jp/ogp.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <Header />
  <main>
    <section class="map-hero">
      <div class="w hero-inner">
        <div>
          <p class="eyebrow">AI Ecosystem Reference</p>
          <h1>{pageTitle}</h1>
          <p class="lead">{pageDescription}</p>
        </div>
        <div class="hero-actions">
          {company?.kind === 'company' && <a class="primary-btn" href={`/company/${graph.company}/`}>{displayName}を見る →</a>}
          <a class="ghost-btn" href="/#ai-ecosystem-map">インタラクティブ版へ →</a>
        </div>
      </div>
    </section>

    <section class="w map-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Supply / Product Flow</p>
          <h2>供給・基盤・製品の流れ</h2>
        </div>
      </div>
      <div class="flow-row">
        {layers.map((layer, index) => (
          <>
            <section class="layer-card">
              <h3>{layer.label || layer.group || displayName}</h3>
              <div class="node-list">
                {layer.subgroups?.length > 0 ? (
                  layer.subgroups.map((subgroup) => (
                    <div class="subgroup">
                      <p>{subgroup.label || subgroup.group}</p>
                      <div>
                        {nodeIdsFromGroup(subgroup).map((id) => {
                          const entity = getEntity(id);
                          return entity.kind === 'company'
                            ? <a href={`/company/${id}/`}>{entity.logoText || entity.name?.slice(0, 2)}<span>{entity.name || id}</span></a>
                            : <span>{entity.logoText || entity.name?.slice(0, 2)}<em>{entity.name || id}</em></span>;
                        })}
                      </div>
                    </div>
                  ))
                ) : (
                  nodeIdsFromGroup(layer).map((id) => {
                    const entity = getEntity(id);
                    return entity.kind === 'company'
                      ? <a href={`/company/${id}/`}>{entity.logoText || entity.name?.slice(0, 2)}<span>{entity.name || id}</span></a>
                      : <span>{entity.logoText || entity.name?.slice(0, 2)}<em>{entity.name || id}</em></span>;
                  })
                )}
              </div>
            </section>
            {index < layers.length - 1 && <div class="layer-arrow">→</div>}
          </>
        ))}
      </div>
    </section>

    <section class="w narrative-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Readable Structure</p>
          <h2>構造概要</h2>
        </div>
      </div>
      <p>{pageDescription}</p>
      <p>{pageTitle}は、{displayName}を中心に、供給元、技術基盤、製品・サービス、顧客、競合関係をAI産業の構造として整理したStoryGraphです。可視化されたノードだけでなく、以下の静的HTMLリストを通じて検索エンジンやAI検索にも読み取りやすい形で公開しています。</p>
      <div class="narrative-grid">
        {layerEntities.map((layer) => (
          <article>
            <h3>{layer.label}</h3>
            <p>{layer.ids.slice(0, 10).map((id) => getEntity(id).name || id).join('、')}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="w narrative-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Players / Dependencies</p>
          <h2>主要プレイヤー・供給元・技術依存</h2>
        </div>
      </div>
      <div class="company-chip-grid">
        {relatedCompanies.map((entity) => (
          <a href={`/company/${entity.id}/`}>{entity.logoText || entity.name?.slice(0, 2)}<span>{entity.name || entity.id}</span></a>
        ))}
      </div>
    </section>

    {bottomEntries.length > 0 && (
      <section class="w relation-panel">
        <div class="section-head">
          <div>
            <p class="eyebrow">Relations</p>
            <h2>資本・提携・競合</h2>
          </div>
        </div>
        <div class="relation-grid">
          {bottomEntries.map((group) => (
            <section>
              <h3>{group.label}</h3>
              <div>
                {group.ids.slice(0, 18).map((id) => {
                  const entity = getEntity(id);
                  return entity.kind === 'company'
                    ? <a href={`/company/${id}/`} title={entity.name}>{entity.logoText || entity.name?.slice(0, 2)}<span>{entity.name || id}</span></a>
                    : <span title={entity.name}>{entity.logoText || entity.name?.slice(0, 2)}<em>{entity.name || id}</em></span>;
                })}
              </div>
            </section>
          ))}
        </div>
      </section>
    )}

    {(relatedArticles.length > 0 || graphArticles.length > 0) && (
      <section class="w related">
        <div class="section-head">
          <div>
            <p class="eyebrow">Related Intelligence</p>
            <h2>関連記事・一次情報</h2>
          </div>
        </div>
        <div class="article-grid">
          {relatedArticles.map((article) => (
            <a href={getArticleUrl(article)}>
              <p>{article.data.category || article.data.category_slug || '記事'}</p>
              <h3>{article.data.title}</h3>
              <span>読む →</span>
            </a>
          ))}
          {graphArticles.map((article) => (
            <a href={article.href}>
              <p>構造ページ</p>
              <h3>{article.title}</h3>
              <span>見る →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="w related source-links">
      <div class="section-head">
        <div>
          <p class="eyebrow">Primary Source Policy</p>
          <h2>一次情報リンク</h2>
        </div>
      </div>
      <div class="article-grid">
        <a href="/primary-sources/">
          <p>PRIMARY SOURCES</p>
          <h3>AI経済新聞が参照する一次情報ソース</h3>
          <span>確認する →</span>
        </a>
        <a href="/methodology/">
          <p>METHODOLOGY</p>
          <h3>StoryGraphと企業DBの構造化手法</h3>
          <span>読む →</span>
        </a>
        {company?.kind === 'company' && (
          <a href={`/company/${graph.company}/`}>
            <p>COMPANY</p>
            <h3>{displayName}の企業DB</h3>
            <span>見る →</span>
          </a>
        )}
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  :global(body) {
    margin: 0;
    background:
      radial-gradient(circle at 22% 0%, rgba(90,158,255,.14), transparent 34rem),
      linear-gradient(180deg, rgba(14,22,40,.9), rgba(7,9,13,0) 520px),
      #07090d;
    color: #f0f4f8;
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1440px); margin-inline: auto; }
  .map-hero { border-bottom: 1px solid rgba(255,255,255,.09); padding: 48px 0 30px; }
  .hero-inner { display: flex; justify-content: space-between; gap: 28px; align-items: end; }
  .eyebrow { margin: 0; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  h1 { margin: 6px 0 0; font-size: clamp(34px, 5vw, 64px); line-height: 1.05; letter-spacing: -.05em; }
  .lead { max-width: 820px; margin: 14px 0 0; color: #b7c4d8; line-height: 1.9; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 9px; justify-content: flex-end; }
  .primary-btn, .ghost-btn { display: inline-flex; border-radius: 999px; padding: 10px 15px; font-size: 12px; font-weight: 900; transition: transform .16s ease; }
  .primary-btn { background: #5cd8ce; color: #07111b; }
  .ghost-btn { border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04); color: #e8eef8; }
  .primary-btn:hover, .ghost-btn:hover { transform: translateY(-2px); }
  .map-panel, .relation-panel, .related, .narrative-panel { margin-top: 24px; border: 1px solid rgba(255,255,255,.10); border-radius: 18px; background: rgba(255,255,255,.035); backdrop-filter: blur(14px); padding: 22px; }
  .section-head { display: flex; justify-content: space-between; gap: 16px; align-items: end; margin-bottom: 16px; }
  .section-head h2 { margin: 4px 0 0; font-size: 24px; letter-spacing: -.03em; }
  .flow-row { display: flex; align-items: stretch; gap: 12px; overflow-x: auto; padding-bottom: 8px; }
  .layer-card { min-width: 245px; max-width: 310px; border: 1px solid rgba(255,255,255,.10); border-radius: 16px; background: rgba(0,0,0,.20); padding: 16px; }
  .layer-card h3 { margin: 0 0 12px; color: #f8fbff; font-size: 15px; }
  .node-list, .subgroup div, .relation-grid section > div { display: flex; flex-wrap: wrap; gap: 8px; }
  .node-list a, .node-list span, .relation-grid a, .relation-grid span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    padding: 7px 10px;
    color: #dbe7f5;
    font-size: 12px;
    font-weight: 800;
  }
  .node-list a::first-letter, .relation-grid a::first-letter { color: #5cd8ce; }
  .node-list em, .relation-grid em { font-style: normal; }
  .subgroup { width: 100%; border-top: 1px solid rgba(255,255,255,.08); padding-top: 10px; }
  .subgroup:first-child { border-top: 0; padding-top: 0; }
  .subgroup p { margin: 0 0 8px; color: #7f8da3; font-size: 11px; font-weight: 900; }
  .layer-arrow { display: grid; place-items: center; color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 20px; font-weight: 900; }
  .relation-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
  .relation-grid section { border: 1px solid rgba(255,255,255,.08); border-radius: 14px; background: rgba(0,0,0,.18); padding: 14px; }
  .relation-grid h3 { margin: 0 0 10px; font-size: 14px; }
  .narrative-panel > p { max-width: 920px; color: #b7c4d8; line-height: 1.95; }
  .narrative-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-top: 16px; }
  .narrative-grid article { border: 1px solid rgba(255,255,255,.08); border-radius: 14px; background: rgba(0,0,0,.18); padding: 14px; }
  .narrative-grid h3 { margin: 0 0 8px; font-size: 14px; }
  .narrative-grid p { margin: 0; color: #b7c4d8; font-size: 12px; line-height: 1.8; }
  .company-chip-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .company-chip-grid a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid rgba(92,216,206,.18);
    border-radius: 999px;
    background: rgba(92,216,206,.065);
    padding: 7px 11px;
    color: #dff8f6;
    font-size: 12px;
    font-weight: 900;
  }
  .company-chip-grid a::first-letter { color: #5cd8ce; }
  .source-links { margin-bottom: 52px; }
  .article-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
  .article-grid a { border: 1px solid rgba(255,255,255,.09); border-radius: 14px; background: rgba(0,0,0,.18); padding: 14px; transition: transform .16s ease, border-color .16s ease; }
  .article-grid a:hover { transform: translateY(-2px); border-color: rgba(92,216,206,.38); }
  .article-grid p { margin: 0 0 8px; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; }
  .article-grid h3 { margin: 0 0 10px; font-size: 14px; line-height: 1.65; }
  .article-grid span { color: #5cd8ce; font-size: 12px; font-weight: 900; }
  @media(max-width: 900px) {
    .hero-inner { flex-direction: column; align-items: flex-start; }
    .relation-grid, .article-grid, .narrative-grid { grid-template-columns: 1fr; }
  }
</style>
