---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const canonicalUrl = "https://aikeizai.jp/methodology/";
const description = "AI経済新聞の分析手法。一次情報を起点に、企業DB、StoryGraph、業界マップ、関連記事を接続し、AI産業の供給網・競合・技術依存を構造化します。";
const steps = [
  ["一次情報の確認", "企業発表、論文、GitHub、IR、政府資料を確認し、原典URL、公開日、ソース種別を整理します。"],
  ["エンティティ化", "企業、モデル、プロダクト、投資家、政策主体を企業DBと関連データへ紐づけます。"],
  ["関係性の抽出", "供給、顧客、投資、提携、競合、技術依存などの関係をStoryGraphとして整理します。"],
  ["静的HTML化", "可視化だけでなく、検索エンジンやAI検索が読める本文、リスト、JSON-LDとして出力します。"],
];
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>分析手法 | AI経済新聞</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content="分析手法 | AI経済新聞" />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://aikeizai.jp/og/policy.svg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://aikeizai.jp/og/policy.svg" />
</head>
<body>
  <Header />
  <main class="w">
    <section class="hero">
      <p class="eyebrow">Methodology</p>
      <h1>AI産業を構造として読むための分析手法</h1>
      <p>{description}</p>
    </section>
    <section class="steps">
      {steps.map(([title, text], index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </section>
    <section class="panel">
      <h2>AI検索・Discoverへの対応</h2>
      <p>AI経済新聞は、記事、Company、Topic、StoryGraphページを相互リンクし、ページ上に静的な説明本文、関係企業リスト、一次情報リンク、BreadcrumbList、CollectionPage、ItemList、Organizationなどの構造化データを配置します。これにより、人間の読者だけでなく、検索エンジンやLLMにも関係性を読み取りやすくします。</p>
      <div><a href="/editorial-policy/">編集方針</a><a href="/storygraph/">StoryGraph</a><a href="/primary-sources/">一次情報</a></div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  :global(body) { margin: 0; background: radial-gradient(circle at 20% 0%, rgba(90,158,255,.13), transparent 34rem), #07090d; color: #f0f4f8; font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif; }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1120px); margin-inline: auto; }
  .hero { padding: 58px 0 24px; }
  .eyebrow { margin: 0; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  h1 { max-width: 820px; margin: 8px 0 0; font-size: clamp(34px, 5vw, 62px); line-height: 1.12; letter-spacing: -.04em; }
  .hero p, article p, .panel p { color: #b7c4d8; line-height: 1.9; }
  .steps { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  article, .panel { border: 1px solid rgba(255,255,255,.10); border-radius: 16px; background: rgba(255,255,255,.035); padding: 22px; }
  article span { color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-weight: 900; }
  h2 { margin: 8px 0 10px; font-size: 22px; }
  .panel { margin: 16px 0 56px; }
  .panel div { display: flex; flex-wrap: wrap; gap: 10px; }
  .panel a { border: 1px solid rgba(92,216,206,.22); border-radius: 999px; background: rgba(92,216,206,.07); padding: 8px 12px; color: #5cd8ce; font-size: 12px; font-weight: 900; }
  @media (max-width: 760px) { .steps { grid-template-columns: 1fr; } }
</style>
