---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CompanyLogoChip from '../components/CompanyLogoChip.astro';
import companiesData from '../data/ecosystem/companies.json';
import storygraphsData from '../data/ecosystem/storygraphs.json';

const isArchivedArticle = (article) =>
  article.data.noindex === true ||
  article.data.indexable === false ||
  article.data.source_status === 'legacy_secondary_source';

const articles = (await getCollection('articles'))
  .filter((article) => !isArchivedArticle(article))
  .sort((a, b) => new Date(b.data.published_at || 0).getTime() - new Date(a.data.published_at || 0).getTime());

const recentArticles = articles.slice(0, 36);
const getArticleUrl = (article) =>
  `/article/${article.data.category_slug || 'business'}/${article.data.article_slug || article.id}/`;

const companyMap = new Map(companiesData.map((company) => [company.id, company]));
const companySignals = Array.from(new Set(recentArticles.flatMap((article) => article.data.companies_json || [])))
  .map((id) => companyMap.get(id))
  .filter(Boolean)
  .slice(0, 12);
const priorityCompanyIds = ['openai', 'nvidia', 'anthropic', 'microsoft', 'google', 'meta', 'xai', 'tsmc', 'amd', 'huggingface'];
const priorityCompanies = priorityCompanyIds.map((id) => companyMap.get(id)).filter(Boolean);

const pickBy = (predicate, limit = 5) => recentArticles.filter(predicate).slice(0, limit);
const hasTopic = (article, terms) => {
  const topics = (article.data.topics_json || []).join(' ').toLowerCase();
  const companies = (article.data.companies_json || []).join(' ').toLowerCase();
  const text = `${article.data.title} ${article.data.category_slug} ${topics} ${companies}`.toLowerCase();
  return terms.some((term) => text.includes(term));
};

const sections = [
  {
    label: 'GPU / Cloud',
    title: 'GPU・クラウド基盤',
    description: 'AI計算資源、半導体、クラウド、データセンター、供給網の変化を追います。',
    articles: pickBy((article) => hasTopic(article, ['gpu', 'nvidia', 'amd', 'tsmc', 'cloud', 'infrastructure', 'semiconductor', 'coreweave'])),
    map: '/map/gpu-supply-chain/',
  },
  {
    label: 'Model / Agent',
    title: '基盤モデル・AIエージェント',
    description: 'モデル競争、API、AI Agent、アプリケーション層の変化を整理します。',
    articles: pickBy((article) => hasTopic(article, ['openai', 'anthropic', 'gemini', 'agent', 'model', 'llm', 'mistral', 'xai'])),
    map: '/map/openai-ecosystem/',
  },
  {
    label: 'OSS',
    title: 'Open Source AI Stack',
    description: 'OSSモデル、開発者基盤、GitHub、推論スタック、配布エコシステムを追跡します。',
    articles: pickBy((article) => hasTopic(article, ['oss', 'open-source', 'github', 'huggingface', 'llama', 'deepseek'])),
    map: '/map/open-source-ai-ecosystem/',
  },
  {
    label: 'Policy',
    title: '政策・規制',
    description: '政府資料、規制当局、輸出規制、AI政策、国際競争の論点を整理します。',
    articles: pickBy((article) => hasTopic(article, ['policy', 'regulation', 'government', 'sec', 'china', 'japan', 'eu'])),
    map: '/map/china-ai-map/',
  },
  {
    label: 'Japan AI',
    title: '日本AI',
    description: '日本企業、国内クラウド、研究開発、政策、AI実装の動きを構造で追います。',
    articles: pickBy((article) => hasTopic(article, ['japan', 'sakana', 'preferred', 'sakura', 'tokyo', '経産省', '日本'])),
    map: '/map/japan-ai/',
  },
];

const priorityThemes = Array.from(new Set(recentArticles.flatMap((article) => article.data.topics_json || []))).slice(0, 12);
const featuredMaps = [
  '/map/nvidia-empire/',
  '/map/openai-ecosystem/',
  '/map/gpu-supply-chain/',
  '/map/ai-agent-wars/',
  '/map/cloud-ai-infrastructure/',
].filter((href) => storygraphsData.length > 0);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AI産業レーダー',
  description: '今週のAI産業の重要テーマ、主要企業、GPU/クラウド、モデル/Agent、OSS、政策、日本AIを構造で読むページ。',
  url: 'https://aikeizai.jp/radar/',
  inLanguage: 'ja',
};
const ogImage = 'https://aikeizai.jp/og/radar.svg';
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI産業レーダー | AI経済新聞</title>
  <meta name="description" content="今週のAI産業で何が動いたかを、重要テーマ、主要企業、GPU/クラウド、モデル/Agent、OSS、政策、日本AIから構造的に確認できます。" />
  <link rel="canonical" href="https://aikeizai.jp/radar/" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="AI産業レーダー | AI経済新聞" />
  <meta property="og:description" content="今週のAI産業で何が動いたかを構造で読む。" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImage} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <Header currentCategory="radar" />
  <main>
    <section class="hero">
      <div class="w hero-inner">
        <div>
          <p class="eyebrow">AI Industry Radar</p>
          <h1>今週のAI産業で何が動いたか</h1>
          <p class="lead">記事を時系列に読むだけでなく、計算資源、モデル、OSS、政策、日本AIの構造変化として把握するためのレーダーページです。</p>
        </div>
        <div class="radar-card">
          <span>{recentArticles.length}</span>
          <p>recent primary-source articles</p>
        </div>
      </div>
    </section>

    <section class="w themes">
      <div class="section-head">
        <div>
          <p class="eyebrow">Weekly Themes</p>
          <h2>今週の重要テーマ</h2>
        </div>
        <a href="/search/">横断検索へ</a>
      </div>
      <div class="theme-row">
        {priorityThemes.map((topic) => <a href={`/topic/${topic}/`}>#{topic}</a>)}
      </div>
    </section>

    <section class="w company-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Company Signals</p>
          <h2>主要企業の動き</h2>
        </div>
      </div>
      <div class="company-grid">
        {(companySignals.length > 0 ? companySignals : priorityCompanies).map((company) => (
          <CompanyLogoChip company={company} variant="card" />
        ))}
      </div>
    </section>

    <section class="w radar-grid">
      {sections.map((section) => (
        <article class="radar-section">
          <div class="section-head compact">
            <div>
              <p class="eyebrow">{section.label}</p>
              <h2>{section.title}</h2>
            </div>
            <a href={section.map}>Map</a>
          </div>
          <p class="desc">{section.description}</p>
          <div class="article-list">
            {(section.articles.length > 0 ? section.articles : recentArticles.slice(0, 3)).map((article) => (
              <a href={getArticleUrl(article)}>
                <span>{article.data.category_slug || 'article'}</span>
                <strong>{article.data.title}</strong>
              </a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="w map-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Structure Links</p>
          <h2>関連StoryGraph</h2>
        </div>
      </div>
      <div class="map-row">
        {featuredMaps.map((href) => (
          <a href={href}>{href.split('/').filter(Boolean).pop()?.replaceAll('-', ' ')}</a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  :global(body) {
    margin: 0;
    background:
      radial-gradient(circle at 22% 0%, rgba(90,158,255,.14), transparent 34rem),
      linear-gradient(180deg, rgba(14,22,40,.9), rgba(7,9,13,0) 520px),
      #07090d;
    color: #f0f4f8;
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1440px); margin-inline: auto; }
  .hero { border-bottom: 1px solid rgba(255,255,255,.09); padding: 52px 0 30px; }
  .hero-inner { display: flex; justify-content: space-between; align-items: end; gap: 28px; }
  .eyebrow { margin: 0; color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 900; letter-spacing: .16em; text-transform: uppercase; }
  h1 { max-width: 940px; margin: 8px 0 0; font-size: clamp(34px, 5vw, 64px); line-height: 1.08; letter-spacing: -.04em; }
  .lead { max-width: 820px; margin: 16px 0 0; color: #b7c4d8; line-height: 1.9; }
  .radar-card { min-width: 220px; border: 1px solid rgba(92,216,206,.24); border-radius: 18px; background: rgba(92,216,206,.07); padding: 18px; }
  .radar-card span { color: #fff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 42px; font-weight: 900; }
  .radar-card p { margin: 4px 0 0; color: #9ff5ee; font-size: 12px; }
  .themes, .company-panel, .map-panel { margin-top: 24px; border: 1px solid rgba(255,255,255,.10); border-radius: 18px; background: rgba(255,255,255,.035); padding: 22px; }
  .section-head { display: flex; justify-content: space-between; gap: 16px; align-items: end; margin-bottom: 16px; }
  .section-head h2 { margin: 4px 0 0; font-size: 24px; letter-spacing: -.03em; }
  .section-head > a { color: #5cd8ce; font-size: 12px; font-weight: 900; white-space: nowrap; }
  .theme-row, .map-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .theme-row a, .map-row a {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 999px;
    background: rgba(255,255,255,.045);
    padding: 8px 12px;
    color: #dbe7f5;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 12px;
    font-weight: 800;
  }
  .company-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
  .radar-section {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 16px;
    background: rgba(0,0,0,.18);
    padding: 16px;
  }
  .radar-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin-top: 24px; }
  .section-head.compact h2 { font-size: 22px; }
  .desc { margin: 0 0 16px; color: #aebbd0; line-height: 1.8; }
  .article-list { display: grid; gap: 8px; }
  .article-list a {
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 12px;
    background: rgba(255,255,255,.035);
    padding: 12px;
  }
  .article-list span { color: #8fdcf6; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; font-weight: 900; text-transform: uppercase; }
  .article-list strong { display: block; margin-top: 6px; color: #fff; font-size: 14px; line-height: 1.65; }
  .map-panel { margin-bottom: 56px; }
  @media (max-width: 900px) {
    .hero-inner { flex-direction: column; align-items: flex-start; }
    .company-grid, .radar-grid { grid-template-columns: 1fr; }
    .radar-card { min-width: 0; width: 100%; box-sizing: border-box; }
  }
</style>
