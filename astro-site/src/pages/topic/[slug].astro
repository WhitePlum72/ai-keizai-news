---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import companiesData from '../../data/ecosystem/companies.json';
import storygraphsData from '../../data/ecosystem/storygraphs.json';

export async function getStaticPaths() {
  const isArchivedArticle = (article) =>
    article.data.noindex === true ||
    article.data.indexable === false ||
    article.data.source_status === 'legacy_secondary_source';
  const articles = (await getCollection('articles')).filter((article) => !isArchivedArticle(article));
  const topicMap = new Map();

  for (const article of articles) {
    for (const topic of article.data.topics_json ?? []) {
      if (!topicMap.has(topic)) topicMap.set(topic, []);
      topicMap.get(topic).push(article);
    }
  }

  return Array.from(topicMap.entries()).map(([slug, topicArticles]) => ({
    params: { slug },
    props: {
      slug,
      articles: topicArticles.sort((a, b) => (b.data.buzz_score || 0) - (a.data.buzz_score || 0)),
    },
  }));
}

const { slug, articles } = Astro.props;
const topicNames = {
  gpu: 'GPU',
  openai: 'OpenAI',
  nvidia: 'NVIDIA',
  agents: 'AIエージェント',
  reasoning: '推論モデル',
  semiconductor: '半導体',
  datacenter: 'データセンター',
  policy: 'AI政策',
  robotics: 'ロボティクス',
  'generative-ai': '生成AI',
};
const topicLabel = topicNames[slug] || slug.split('-').map((word) => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
const description = `${topicLabel}に関するAI業界ニュース、企業動向、技術トレンドを構造で整理したトピックページです。`;
const canonicalUrl = `https://aikeizai.jp/topic/${slug}/`;
const companyMap = new Map(companiesData.map((company) => [company.id, company]));
const companyCounts = new Map();
for (const article of articles) {
  for (const company of article.data.companies_json ?? []) {
    companyCounts.set(company, (companyCounts.get(company) || 0) + 1);
  }
}
const relatedCompanies = Array.from(companyCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([id]) => companyMap.get(id))
  .filter(Boolean)
  .slice(0, 12);
const mapSlugOverrides = {
  nvidia: 'nvidia-empire',
  openai: 'openai-ecosystem',
  gpu: 'gpu-supply-chain',
  semiconductor: 'gpu-supply-chain',
  agents: 'ai-agent-wars',
  deepseek: 'china-ai-map',
  china: 'china-ai-map',
  japan: 'japan-ai',
  'open-source': 'open-source-ai-ecosystem',
};
const topicMapSlug = mapSlugOverrides[slug] || (storygraphsData.some((graph) => graph.company === slug) ? `${slug}-ecosystem` : null);
const relatedMaps = Array.from(new Set([
  topicMapSlug,
  ...relatedCompanies
    .map((company) => storygraphsData.some((graph) => graph.company === company.id) ? `${company.id}-ecosystem` : null),
].filter(Boolean))).slice(0, 5);
const topicSummary = `${topicLabel}は、AI産業の中で企業戦略、技術基盤、供給網、資本市場、政策判断にまたがるテーマです。AI経済新聞では関連記事、関連企業、StoryGraphを接続し、個別ニュースを構造として追跡します。`;
const getArticleUrl = (article) => `/article/${article.data.category_slug || 'business'}/${article.data.article_slug || article.id}/`;
const getCatLabel = (id) => ({
  model: '基盤モデル',
  business: 'ビジネス',
  markets: '市場・株価',
  infrastructure: 'AIインフラ',
  research: '研究',
  policy: '政策',
  products: 'プロダクト',
  agents: 'AIエージェント',
  robotics: 'ロボティクス',
  'generative-ai': '生成AI',
}[id] || id || '記事');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: `${topicLabel}の記事一覧`,
      description,
      url: canonicalUrl,
      inLanguage: 'ja',
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: articles.slice(0, 20).map((article, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: article.data.title,
          url: `https://aikeizai.jp${getArticleUrl(article)}`,
        })),
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://aikeizai.jp/' },
        { '@type': 'ListItem', position: 2, name: topicLabel, item: canonicalUrl },
      ],
    },
  ],
};
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{topicLabel}の記事一覧 | AI経済新聞</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={`${topicLabel} | AI経済新聞`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://aikeizai.jp/ogp.png" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>

<body>
  <Header />
  <main>
    <section class="topic-hero">
      <div class="w">
        <p class="eyebrow">Topic Intelligence</p>
        <h1>#{topicLabel}</h1>
        <p>{description}</p>
        <span>{articles.length}件の記事</span>
      </div>
    </section>

    <div class="w layout">
      <main>
        <section class="topic-panel">
          <p class="eyebrow">Topic Summary</p>
          <h2>{topicLabel}の位置づけ</h2>
          <p>{topicSummary}</p>
          <div class="summary-grid">
            <article><strong>{articles.length}</strong><span>関連記事</span></article>
            <article><strong>{relatedCompanies.length}</strong><span>関連企業</span></article>
            <article><strong>{relatedMaps.length}</strong><span>関連Map</span></article>
          </div>
        </section>

        {relatedCompanies.length > 0 && (
          <section class="topic-panel">
            <p class="eyebrow">Related Companies</p>
            <h2>関連企業</h2>
            <div class="chip-grid">
              {relatedCompanies.map((company) => (
                <a href={`/company/${company.id}/`}>
                  {company.logoText || company.name.slice(0, 2)}
                  <span>{company.name}</span>
                </a>
              ))}
            </div>
          </section>
        )}

        {relatedMaps.length > 0 && (
          <section class="topic-panel">
            <p class="eyebrow">Related Maps</p>
            <h2>関連Map</h2>
            <div class="map-grid">
              {relatedMaps.map((map) => <a href={`/map/${map}/`}>{map.replaceAll('-', ' ')}</a>)}
            </div>
          </section>
        )}

        {articles.length === 0 ? (
          <div class="empty">この記事に関連する記事はまだありません。</div>
        ) : (
          <div class="article-list">
            {articles.map((article) => (
              <a class="article-card" href={getArticleUrl(article)}>
                <img src={article.data.image_url || '/ogp.png'} alt={article.data.title} loading="lazy" decoding="async" />
                <div class="card-body">
                  <div class="card-meta">
                    <span>{getCatLabel(article.data.category_slug)}</span>
                    <time>{article.data.published_at || ''}</time>
                  </div>
                  <h2>{article.data.title}</h2>
                  <p>{article.data.description || article.data.meta_description || 'AI業界の構造変化を読み解きます。'}</p>
                  <strong>読む →</strong>
                </div>
              </a>
            ))}
          </div>
        )}
      </main>
      <Sidebar />
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
  :global(body) {
    margin: 0;
    background:
      radial-gradient(circle at 20% 0%, rgba(90,158,255,.13), transparent 34rem),
      linear-gradient(180deg, rgba(14,22,40,.9), rgba(7,9,13,0) 520px),
      #07090d;
    color: #f0f4f8;
    font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  :global(a) { color: inherit; text-decoration: none; }
  .w { width: min(100% - 32px, 1440px); margin-inline: auto; }
  .topic-hero { padding: 46px 0 30px; border-bottom: 1px solid rgba(255,255,255,.09); }
  .eyebrow { margin: 0; color: #5a9eff; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  h1 { margin: 6px 0 0; font-size: clamp(34px, 5vw, 62px); line-height: 1.08; letter-spacing: -.05em; }
  .topic-hero p { max-width: 760px; color: #b7c4d8; line-height: 1.9; }
  .topic-hero span { display: inline-flex; border: 1px solid rgba(255,255,255,.10); border-radius: 999px; background: rgba(255,255,255,.04); padding: 7px 11px; color: #dbe7f5; font-size: 12px; }
  .layout { display: grid; grid-template-columns: minmax(0, 1fr) 340px; gap: 24px; padding: 28px 0 52px; }
  .topic-panel {
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 16px;
    background: rgba(255,255,255,.035);
    padding: 20px;
    margin-bottom: 14px;
  }
  .topic-panel h2 { margin: 4px 0 10px; font-size: 22px; letter-spacing: -.03em; }
  .topic-panel p { color: #b7c4d8; line-height: 1.9; }
  .summary-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
  .summary-grid article { border: 1px solid rgba(255,255,255,.08); border-radius: 12px; background: rgba(0,0,0,.18); padding: 13px; }
  .summary-grid strong { display: block; color: #5cd8ce; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 22px; }
  .summary-grid span { color: #b7c4d8; font-size: 12px; }
  .chip-grid, .map-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip-grid a, .map-grid a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid rgba(92,216,206,.18);
    border-radius: 999px;
    background: rgba(92,216,206,.065);
    padding: 7px 11px;
    color: #dff8f6;
    font-size: 12px;
    font-weight: 900;
  }
  .map-grid a { font-family: 'IBM Plex Mono', ui-monospace, monospace; text-transform: uppercase; }
  .article-list { display: grid; gap: 12px; }
  .article-card { display: grid; grid-template-columns: 210px 1fr; overflow: hidden; border: 1px solid rgba(255,255,255,.10); border-radius: 16px; background: rgba(255,255,255,.035); transition: transform .16s ease, border-color .16s ease; }
  .article-card:hover { transform: translateY(-2px); border-color: rgba(92,216,206,.36); }
  .article-card img { width: 100%; height: 100%; min-height: 150px; object-fit: cover; background: rgba(255,255,255,.04); }
  .card-body { padding: 16px; }
  .card-meta { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; color: #7f8da3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; }
  .card-meta span { border-radius: 999px; background: rgba(90,158,255,.16); color: #9ec5ff; padding: 4px 8px; }
  .article-card h2 { margin: 10px 0 8px; color: #f8fbff; font-size: 18px; line-height: 1.55; }
  .article-card p { margin: 0; color: #aebbd0; font-size: 13px; line-height: 1.75; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .article-card strong { display: inline-flex; margin-top: 12px; color: #5cd8ce; font-size: 12px; }
  .empty { border: 1px solid rgba(255,255,255,.10); border-radius: 16px; background: rgba(255,255,255,.035); padding: 34px; color: #aebbd0; text-align: center; }
  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; }
    .article-card { grid-template-columns: 1fr; }
    .article-card img { aspect-ratio: 16 / 9; min-height: 0; }
    .summary-grid { grid-template-columns: 1fr; }
  }
</style>
